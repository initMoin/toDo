      }
    },
    "Stop syncing with iCloud and keep your ToDos on this device.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "توقف عن المزامنة معiCloudواحتفظ بمهامك على هذا الجهاز."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Deje de sincronizar coniCloudy mantenga sus tareas pendientes en este dispositivo."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloudके साथ सिंक करना बंद करें और अपने ToDos को इस डिवाइस पर रखें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Interrompi la sincronizzazione coniCloude mantieni le tue cose da fare su questo dispositivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloudとの同期を停止し、ToDo をこのデバイスに保持します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Berhenti menyegerak denganiClouddan simpan Tugasan anda pada peranti ini."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "หยุดการซิงค์กับiCloudและเก็บสิ่งที่ต้องทำของคุณไว้ในอุปกรณ์นี้"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloudکے ساتھ مطابقت پذیری بند کریں اور اپنے ٹُڈُوز کو اس ڈیوائس پر رکھیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "停止与iCloud同步并将您的待办事项保留在此设备上。"
          }
        }
      }
    },

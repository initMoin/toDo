        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Gunakan bunyi yang lebih jelas untuk peringatan."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ใช้เสียงที่คมชัดขึ้นสำหรับการเตือนความจำ"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "واضح یاد دہانیوں کے لیے تیز آواز استعمال کریں۔"
          }
        },
        "zh-Hans": {

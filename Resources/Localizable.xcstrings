    "Use the system default notification sound.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدم صوت إشعار النظام الافتراضي."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilice el sonido de notificación predeterminado del sistema."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सिस्टम डिफ़ॉल्ट अधिसूचना ध्वनि का उपयोग करें."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa il suono di notifica predefinito del sistema."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "システム標準の通知音を使用します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Gunakan bunyi pemberitahuan lalai sistem."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ใช้เสียงแจ้งเตือนเริ่มต้นของระบบ"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "سسٹم کا ڈیفالٹ اطلاع صوت استعمال کریں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用系统默认通知声音。"
          }
        }
      }
    },
    "Use ToDo Sync to keep what matters available across iPhone, Android, and web.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدم مزامنة تُدُ لإبقاء ما يهم متاحًا عبر iPhone وAndroid والويب."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilice ToDo Sync para mantener lo importante disponible eniPhone,Androidy la web."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "iPhone,Androidऔर वेब पर जो कुछ भी उपलब्ध है उसे बनाए रखने के लिए ToDo Sync का उपयोग करें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa ToDo Sync per avere ciò che conta su iPhone, Android e web."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo Syncを使うと、大切な項目をiPhone、Android、Webで使えます。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Gunakan ToDo Sync untuk memastikan perkara penting tersedia merentas iPhone, Android dan web."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ใช้ ToDo Sync เพื่อให้สิ่งสำคัญพร้อมใช้งานบน iPhone, Android และเว็บ"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "جو اہم ہے اسے iPhone، Android، اور ویب پر دستیاب رکھنے کے لیے ٹُڈُو سنک استعمال کریں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用 ToDo Sync 让重要内容在iPhone、Android和 Web 上保持可用。"
          }
        }
      }
    },
    "Use your own words. Submit project proposal, pick up groceries, or call Sarah at 4 PM all work.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدم كلماتك الخاصة. أرسل مقترح المشروع، أو احصل على البقالة، أو اتصل بسارة في الساعة 4 مساءً."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa tus propias palabras. Envíe una propuesta de proyecto, recoja alimentos o llame a Sarah a las 4 p. m., todo funciona."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपने स्वंय के शब्द प्रयोग करो। प्रोजेक्ट प्रस्ताव सबमिट करें, किराने का सामान लें, या सभी काम के लिए शाम 4 बजे सारा को कॉल करें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa le tue parole. Invia una proposta di progetto, ritira la spesa o chiama Sarah alle 16:00, tutto funziona."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自分の言葉を使ってください。プロジェクトの提案書を提出したり、食料品を買ったり、午後 4 時にサラに電話したりするのはすべて仕事です。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Gunakan perkataan anda sendiri. Serahkan cadangan projek, ambil barang runcit atau hubungi Sarah pada pukul 4 petang semua kerja."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ใช้คำพูดของคุณเอง ส่งข้อเสนอโครงการ รับของชำ หรือโทรหา Sarah เวลา 16.00 น. ทุกงาน"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اپنے الفاظ استعمال کریں۔ پروجیکٹ پروپوزل جمع کروائیں، گروسری اٹھائیں، یا سارا کام شام 4 بجے سارہ کو کال کریں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用你自己的话。提交项目提案、取杂货或在下午 4 点给莎拉打电话，这些都是工作。"
          }
        }
      }
    },
    "Using Apple Park until location access is available.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدامApple Parkحتى يتوفر الوصول إلى الموقع."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "UsandoApple Parkhasta que el acceso a la ubicación esté disponible."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्थान पहुंच उपलब्ध होने तकApple Parkका उपयोग करना।"
          }

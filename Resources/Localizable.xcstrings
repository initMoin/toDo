    "Sending delete markers so other devices stay consistent.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إرسال علامات الحذف حتى تظل الأجهزة الأخرى متسقة."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Envío de marcadores de eliminación para que otros dispositivos se mantengan consistentes."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "डिलीट मार्कर भेजना ताकि अन्य डिवाइस सुसंगत रहें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Invio di marcatori di eliminazione in modo che gli altri dispositivi rimangano coerenti."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "他のデバイスの一貫性を保つために削除マーカーを送信します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Menghantar penanda padam supaya peranti lain kekal konsisten."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การส่งเครื่องหมายลบเพื่อให้อุปกรณ์อื่นๆ มีความสอดคล้องกัน"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ڈیلیٹ مارکر بھیجے جا رہے ہیں تاکہ دوسرے آلات مستقل رہیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "发送删除标记，以便其他设备保持一致。"
          }
        }
      }
    },
    "Sending this device's latest changes.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",

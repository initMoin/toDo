    "%@ toDōs changed on more than one device. Choose which versions to keep.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تغيرت %@ تُدُس على أكثر من جهاز. اختر النسخ التي تريد الاحتفاظ بها."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ toDōs cambiaron en mas de un dispositivo. Elige que versiones conservar."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ toDōs एक से अधिक डिवाइस पर बदले। चुनें कि कौन से संस्करण रखने हैं।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ toDō sono cambiati su piu dispositivi. Scegli quali versioni tenere."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 件のtoDōが複数のデバイスで変更されました。残すバージョンを選んでください。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ toDō berubah pada lebih daripada satu peranti. Pilih versi yang mahu disimpan."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō %@ รายการถูกเปลี่ยนบนมากกว่าหนึ่งอุปกรณ์ เลือกเวอร์ชันที่จะเก็บไว้"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ toDōs ایک سے زیادہ ڈیوائسز پر بدلے ہیں۔ رکھنے والے ورژن منتخب کریں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 个 toDō 在多台设备上发生变化。请选择要保留的版本。"
          }
        }
      }
    },
    "%@ unused tag(s) will be permanently removed.": {
      "localizations": {

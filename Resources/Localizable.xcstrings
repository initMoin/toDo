    "Use a quieter two-note reminder sound.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدم صوت تذكير هادئًا بنغمتين."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilice un sonido recordatorio de dos notas más silencioso."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक शांत दो-नोट अनुस्मारक ध्वनि का उपयोग करें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa un suono promemoria più discreto a due note."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "控えめな2音のリマインダー音を使用します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Gunakan bunyi peringatan dua nada yang lebih lembut."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ใช้เสียงเตือนความจำสองโน้ตที่นุ่มกว่า"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "زیادہ خاموش دو نوٹ والی یاد دہانی آواز استعمال کریں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用更安静的两音符提醒声音。"
          }
        }
      }
    },
    "Use a sharper sound for clear reminders.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدم صوتًا أكثر وضوحًا للتذكيرات."
          }

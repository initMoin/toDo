    "Time-sensitive delivery follows the system notification settings.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتبع التسليم الحساس للوقت إعدادات إشعارات النظام."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La entrega urgente sigue la configuración de notificación del sistema."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "समय-संवेदनशील डिलीवरी सिस्टम अधिसूचना सेटिंग्स का पालन करती है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La consegna con scadenza temporale segue le impostazioni di notifica del sistema."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "時間制限のある配信は、システムの通知設定に従います。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Penghantaran sensitif masa mengikut tetapan pemberitahuan sistem."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การจัดส่งตามเวลาเป็นไปตามการตั้งค่าการแจ้งเตือนของระบบ"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "وقت کے لحاظ سے حساس ڈیلیوری سسٹم کی اطلاع کی ترتیبات کی پیروی کرتی ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "时间敏感的交付遵循系统通知设置。"
          }
        }
      }
    },
    "Time-sensitive delivery is enabled.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم تمكين التسليم الحساس للوقت."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La entrega urgente está habilitada."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "समय-संवेदनशील डिलीवरी सक्षम है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La consegna urgente è abilitata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "時間制限のある配信が有効になっています。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Penghantaran sensitif masa didayakan."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เปิดใช้งานการจัดส่งแบบคำนึงถึงเวลาแล้ว"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "وقت کے لحاظ سے حساس ڈیلیوری فعال ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "启用时间敏感的交付。"
          }
        }
      }
    },
    "Time-sensitive delivery is turned off in system settings.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم إيقاف التسليم الحساس للوقت في إعدادات النظام."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La entrega urgente está desactivada en la configuración del sistema."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सिस्टम सेटिंग्स में समय-संवेदनशील डिलीवरी बंद है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La consegna urgente è disattivata nelle impostazioni di sistema."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "時間制限のある配信はシステム設定でオフになっています。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Penghantaran sensitif masa dimatikan dalam tetapan sistem."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การจัดส่งแบบคำนึงถึงเวลาถูกปิดในการตั้งค่าระบบ"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "وقت کے لحاظ سے حساس ڈیلیوری سسٹم کی ترتیبات میں بند ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "系统设置中关闭了时间敏感的传送。"
          }
        }
      }
    },
    "Time-sensitive delivery is unavailable on this device.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "التسليم الحساس للوقت غير متاح على هذا الجهاز."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",

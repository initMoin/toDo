    "Best for Apple devices. Uses your private iCloud storage.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الأفضل لأجهزةApple. يستخدم مساحة تخزينiCloudالخاصة بك."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lo mejor para dispositivosApple. Utiliza su almacenamiento privadoiCloud."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Appleउपकरणों के लिए सर्वश्रेष्ठ। आपके निजीiCloudसंग्रहण का उपयोग करता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ideale per i dispositivi ZXPLACEholder0ZX. Utilizza il tuo spazio di archiviazione privato ZXPLACEholder1ZX."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Appleデバイスに最適です。プライベートiCloudストレージを使用します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Terbaik untuk perantiApple. Menggunakan storaniCloudperibadi anda."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ดีที่สุดสำหรับอุปกรณ์Appleใช้ที่เก็บข้อมูลiCloudส่วนตัวของคุณ"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "Appleآلات کے لیے بہترین۔ آپ کا نجیiCloudاسٹوریج استعمال کرتا ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "最适合Apple设备。使用您的私人iCloud存储。"
          }
        }
      }
    },
    "Best for iPhone, Android, and web. Uses your ToDo account.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الأفضل لـiPhoneوAndroidوالويب. يستخدم حساب تُدُ الخاص بك."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lo mejor paraiPhone,Androidy web. Utiliza su cuenta ToDo."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "iPhone,Androidऔर वेब के लिए सर्वश्रेष्ठ। आपके टूडू खाते का उपयोग करता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ideale per ZXPLACEholder0ZX, ZXPLACEholder1ZX e Web. Utilizza il tuo account ToDo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iPhone、Android、およびウェブに最適です。 ToDo アカウントを使用します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Terbaik untukiPhone,Androiddan web. Menggunakan akaun ToDo anda."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ดีที่สุดสำหรับiPhone,Androidและเว็บ ใช้บัญชีสิ่งที่ต้องทำของคุณ"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "iPhone،Android، اور ویب کے لیے بہترین۔ آپ کا ٹُڈُو اکاؤنٹ استعمال کرتا ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "最适合iPhone、Android和网络。使用您的待办事项帐户。"
          }
        }
      }
    },
    "Breaks through Focus when the ToDo needs immediate attention.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يخترقFocusعندما يحتاج تُدُ إلى اهتمام فوري."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "AtraviesaFocuscuando la tarea pendiente necesita atención inmediata."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जब ToDo पर तत्काल ध्यान देने की आवश्यकता होती है तोFocusको तोड़ता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "AttraversaFocusquando l'attività da fare richiede attenzione immediata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo に直ちに対応する必要がある場合、Focusを突破します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "MenerobosFocusapabila Tugasan memerlukan perhatian segera."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "แยกFocusเมื่อ ToDo ต้องการความสนใจทันที"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "Focusکے ذریعے ٹوٹ جاتا ہے جب ٹُڈُو کو فوری توجہ کی ضرورت ہوتی ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当 ToDo 需要立即关注时突破Focus。"
          }
        }
      }
    },

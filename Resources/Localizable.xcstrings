    "That ToDo could not be found.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذّر العثور على ذلك تُدُ."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo encontrar esa tarea pendiente."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "वह ToDo नहीं मिल सका."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile trovare quel ToDo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "そのToDoが見つかりませんでした。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo itu tidak ditemui."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ไม่พบ ToDo นั้น"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "وہ ٹُڈُو نہیں مل سکا۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "找不到该 ToDo。"
          }
        }
      }
    },
    "That ToDo may have been deleted or has not synced to this device yet.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ربما تم حذف ذلك تُدُ أو لم تتم مزامنته مع هذا الجهاز بعد."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Es posible que esa tarea pendiente se haya eliminado o aún no se haya sincronizado con este dispositivo."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "वह ToDo शायद हटा दिया गया है या अभी तक इस डिवाइस से समन्वयित नहीं हुआ है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Quel ToDo potrebbe essere stato eliminato o non ancora sincronizzato su questo dispositivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "そのToDoは削除されたか、まだこのデバイスに同期されていない可能性があります。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo itu mungkin telah dipadam atau belum disegerakkan ke peranti ini."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo นั้นอาจถูกลบหรือยังไม่ได้ซิงค์มายังอุปกรณ์นี้"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "وہ ٹُڈُو شاید حذف ہو چکا ہے یا ابھی اس ڈیوائس پر سنک نہیں ہوا۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该待办事项可能已被删除或尚未同步到此设备。"
          }
        }
      }
    },
    "The last sync attempt failed. Tap refresh to try again.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فشلت محاولة المزامنة الأخيرة. انقر فوق تحديث للمحاولة مرة أخرى."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El último intento de sincronización falló. Toca actualizar para volver a intentarlo."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अंतिम समन्वयन प्रयास विफल रहा. पुनः प्रयास करने के लिए ताज़ा करें टैप करें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'ultimo tentativo di sincronizzazione non è riuscito. Tocca Aggiorna per riprovare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最後の同期試行は失敗しました。再試行するには、「更新」をタップします。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Percubaan penyegerakan terakhir gagal. Ketik muat semula untuk mencuba lagi."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ความพยายามในการซิงค์ครั้งล่าสุดล้มเหลว แตะรีเฟรชเพื่อลองอีกครั้ง"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "مطابقت پذیری کی آخری کوشش ناکام ہوگئی۔ دوبارہ کوشش کرنے کے لیے ریفریش کو تھپتھپائیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "上次同步尝试失败。点击刷新重试。"
          }
        }
      }
    },
    "These ToDos changed on another device while this device had unsynced edits. Choose the version that should continue syncing.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تغيّرت هذه تُدُس على جهاز آخر بينما كانت لدى هذا الجهاز تعديلات غير متزامنة. اختر الإصدار الذي يجب أن يستمر في المزامنة."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Estas tareas pendientes cambiaron en otro dispositivo mientras este dispositivo tenía ediciones no sincronizadas. Elija la versión que debe continuar sincronizándose."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ये ToDos किसी अन्य डिवाइस पर बदल गए जबकि इस डिवाइस में अनसिंक किए गए संपादन थे। वह संस्करण चुनें जिसमें समन्वयन जारी रहना चाहिए."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questi ToDo sono cambiati su un altro dispositivo mentre questo aveva modifiche non sincronizzate. Scegli la versione che deve continuare a sincronizzarsi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このデバイスに未同期の編集がある間に、これらのToDoが別のデバイスで変更されました。同期を続けるバージョンを選んでください。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo ini berubah pada peranti lain semasa peranti ini mempunyai edit belum disegerakkan. Pilih versi yang patut terus disegerakkan."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo เหล่านี้ถูกเปลี่ยนบนอุปกรณ์อื่นขณะที่อุปกรณ์นี้มีการแก้ไขที่ยังไม่ได้ซิงค์ เลือกเวอร์ชันที่จะซิงค์ต่อ"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "یہ ٹُڈُوز کسی دوسرے ڈیوائس پر تبدیل ہوئے جبکہ اس ڈیوائس پر غیر سنک شدہ ترامیم تھیں۔ وہ ورژن منتخب کریں جو سنک جاری رکھے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这些待办事项在另一台设备上发生了更改，而该设备有未同步的编辑。选择应继续同步的版本。"
          }
        }
      }
    },
    "This cannot be undone.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يمكن التراجع عن هذا."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto no se puede deshacer."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इसे असंपादित नहीं किया जा सकता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa azione non può essere annullata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この操作は取り消せません。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tindakan ini tidak boleh dibuat asal."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การดำเนินการนี้ไม่สามารถย้อนกลับได้"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "یہ واپس نہیں ہو سکتا۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此操作无法撤消。"
          }
        }
      }
    },
    "This Device Only": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هذا الجهاز فقط"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo este dispositivo"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "केवल यह डिवाइस"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo questo dispositivo"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このデバイスのみ"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Peranti Ini Sahaja"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "อุปกรณ์นี้เท่านั้น"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "صرف یہ آلہ"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅此设备"
          }
        }
      }
    },
    "This option will appear in the %@ snooze menu.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيظهر هذا الخيار في قائمة غفوة %@."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta opción aparecerá en el menú de repetición de alarma%@."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह विकल्प%@स्नूज़ मेनू में दिखाई देगा।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa opzione apparirà nel menu posticipa %@."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このオプションは%@のスヌーズメニューに表示されます。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pilihan ini akan muncul dalam menu tunda %@."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ตัวเลือกนี้จะแสดงในเมนูเลื่อนเตือน %@"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "یہ آپشن %@ اسنوز مینو میں ظاہر ہوگا۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该选项将出现在%@贪睡菜单中。"
          }
        }
      }
    },
    "This permanently deletes all items in the trash. This cannot be undone.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحذف هذا كل العناصر في سلة المهملات نهائيًا. لا يمكن التراجع عن هذا."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto elimina permanentemente todos los elementos de la papelera. Esto no se puede deshacer."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह ट्रैश में मौजूद सभी आइटम को स्थायी रूप से हटा देता है। इसे असंपादित नहीं किया जा सकता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Elimina definitivamente tutti gli elementi nel cestino. Questa azione non può essere annullata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ゴミ箱内のすべての項目を完全に削除します。この操作は取り消せません。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Ini memadam semua item dalam sampah secara kekal. Tindakan ini tidak boleh dibuat asal."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การดำเนินการนี้จะลบรายการทั้งหมดในถังขยะอย่างถาวรและไม่สามารถย้อนกลับได้"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "یہ ردی کے تمام آئٹمز مستقل طور پر حذف کرتا ہے۔ یہ واپس نہیں ہو سکتا۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这将永久删除垃圾箱中的所有项目。此操作无法撤消。"
          }
        }
      }
    },
    "This permanently deletes every completed and archived ToDo.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحذف هذا كل تُدُ مكتمل ومؤرشف نهائيًا."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto elimina permanentemente todas las tareas pendientes completadas y archivadas."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह प्रत्येक पूर्ण और संग्रहीत ToDo को स्थायी रूप से हटा देता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Elimina definitivamente ogni ToDo completato e archiviato."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "完了およびアーカイブ済みのToDoをすべて完全に削除します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Ini memadam setiap ToDo selesai dan diarkibkan secara kekal."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ลบ ToDo ที่เสร็จแล้วและเก็บถาวรทั้งหมดอย่างถาวร"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "یہ ہر مکمل اور آرکائیو شدہ ٹُڈُو مستقل طور پر حذف کرتا ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这将永久删除每个已完成并存档的待办事项。"
          }
        }
      }
    },
    "This removes all existing tags and clears tag links on ToDos and nanoDos.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يزيل هذا كل الوسوم الموجودة ويمسح روابط الوسوم على تُدُس ونَنُدُس."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto elimina todas las etiquetas existentes y borra los enlaces de etiquetas en ToDos y nanoDos."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह सभी मौजूदा टैग हटा देता है और ToDos और nanoDos पर टैग लिंक साफ़ कर देता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rimuove tutti i tag esistenti e cancella i collegamenti tag su ToDo e nanoDo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "既存のタグをすべて削除し、ToDoとnanoDoのタグリンクをクリアします。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Ini membuang semua tag sedia ada dan mengosongkan pautan tag pada ToDo dan nanoDo."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ลบแท็กที่มีอยู่ทั้งหมดและล้างลิงก์แท็กบน ToDo และ nanoDo"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "یہ تمام موجودہ ٹیگز ہٹاتا ہے اور ٹُڈُوز اور نَینوڈوز پر ٹیگ روابط صاف کرتا ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这将删除所有现有标签并清除 ToDos 和 nanoDos 上的标签链接。"
          }
        }
      }
    },
    "This removes the selected ToDo.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يزيل هذا تُدُ المحدد."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto elimina la tarea pendiente seleccionada."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह चयनित ToDo को हटा देता है."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rimuove il ToDo selezionato."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択したToDoを削除します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Ini membuang ToDo yang dipilih."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",

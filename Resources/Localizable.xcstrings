            "value": "年"
          }
        }
      }
    },
    "Yes, Reset Everything": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "نعم، إعادة ضبط كل شيء"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sí, restablecer todo"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हाँ, सब कुछ रीसेट करें"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sì, reimposta tutto"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "はい、すべてリセット"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Ya, tetapkan semula semuanya"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ใช่ รีเซ็ตทั้งหมด"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ہاں، سب کچھ ری سیٹ کریں"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "是的，重置一切"
          }
        }
      }
    },
    "You're caught up. Nothing needs urgent attention right now.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أنت على المسار الصحيح. لا شيء يحتاج إلى انتباه عاجل الآن."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Estás al día. Nada necesita atención urgente ahora mismo."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आप अभी संभले हुए हैं। अभी किसी चीज़ पर तुरंत ध्यान देने की ज़रूरत नहीं है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sei in pari. Nulla richiede attenzione urgente in questo momento."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今は順調です。すぐに対応が必要なものはありません。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Anda sudah terkawal. Tiada apa-apa yang perlukan perhatian segera sekarang."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ตอนนี้คุณตามทันแล้ว ไม่มีอะไรต้องรีบจัดการทันที"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "آپ ابھی سنبھلے ہوئے ہیں۔ اس وقت کسی چیز کو فوری توجہ کی ضرورت نہیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你现在已经跟上了。暂时没有需要紧急处理的事项。"
          }
        }
      }
    },
    "You're ready.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أنت جاهز."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Estás listo."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आप तैयार हैं."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sei pronto."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "準備は完了です。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Anda sudah bersedia."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "คุณพร้อมแล้ว"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "آپ تیار ہیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你准备好了。"
          }
        }
      }
    },
    "Your ": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الخاص بك "
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Su"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपका"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tuo "
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "あなたの"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Anda "
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ของคุณ "
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "آپ کا "
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的"
          }
        }
      }
    },
    "Your active list is currently in a low-pressure state.": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قائمتك النشطة حاليًا في حالة ضغط منخفض."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu lista activa está actualmente en un estado de baja presión."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपकी सक्रिय सूची अभी कम दबाव की स्थिति में है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La tua lista attiva è attualmente in uno stato di bassa pressione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在のアクティブリストは低プレッシャーの状態です。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Senarai aktif anda kini berada dalam keadaan tekanan rendah."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "รายการที่ใช้งานอยู่ของคุณตอนนี้มีแรงกดดันต่ำ"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "آپ کی فعال فہرست اس وقت کم دباؤ کی حالت میں ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的活动列表目前处于低压力状态。"
          }
        }
      }
    },
    "Your first toDo is now active. From here, you can complete, archive, and refine your workflow over time.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أصبحت المهام الأولى الخاصة بك نشطة الآن. ومن هنا، يمكنك إكمال سير العمل وأرشفته وتحسينه بمرور الوقت."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu primera tarea pendiente ya está activa. Desde aquí, puede completar, archivar y perfeccionar su flujo de trabajo con el tiempo."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपका पहला कार्य अब सक्रिय है. यहां से, आप समय के साथ अपने वर्कफ़्लो को पूरा, संग्रहित और परिष्कृत कर सकते हैं।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La tua prima cosa da fare è ora attiva. Da qui puoi completare, archiviare e perfezionare il tuo flusso di lavoro nel tempo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最初の ToDo がアクティブになりました。ここから、時間をかけてワークフローを完了、アーカイブ、改良することができます。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo pertama anda kini aktif. Dari sini, anda boleh melengkapkan, mengarkibkan dan memperhalusi aliran kerja anda dari semasa ke semasa."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "สิ่งที่ต้องทำแรกของคุณเปิดใช้งานแล้ว จากที่นี่ คุณสามารถดำเนินการ เก็บถาวร และปรับปรุงขั้นตอนการทำงานของคุณเมื่อเวลาผ่านไป"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "آپ کا پہلا کام اب فعال ہے۔ یہاں سے، آپ وقت کے ساتھ ساتھ اپنے ورک فلو کو مکمل، آرکائیو اور بہتر کر سکتے ہیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您的第一个待办事项现已激活。从这里，您可以随着时间的推移完成、存档和完善您的工作流程。"
          }
        }
      }
    },
    "Your patterns stay private. Insights simply help you see what deserves attention next.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تبقى أنماطك خاصة. تساعدك الرؤى فقط على معرفة ما يستحق الانتباه بعد ذلك."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus patrones permanecen privados. Insights solo te ayuda a ver qué merece atención después."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपके पैटर्न निजी रहते हैं। इनसाइट्स सिर्फ़ यह दिखाते हैं कि आगे किस पर ध्यान देना चाहिए।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I tuoi pattern restano privati. Gli approfondimenti ti aiutano solo a capire cosa merita attenzione dopo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "あなたのパターンは非公開のままです。インサイトは次に注目すべきことを見つけるためだけのものです。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Corak anda kekal peribadi. Wawasan hanya membantu anda melihat perkara yang patut diberi perhatian seterusnya."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "รูปแบบของคุณยังคงเป็นส่วนตัว ข้อมูลเชิงลึกเพียงช่วยให้เห็นว่าสิ่งใดควรได้รับความสนใจต่อไป"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "آپ کے نمونے نجی رہتے ہیں۔ بصیرتیں صرف یہ دکھانے میں مدد کرتی ہیں کہ آگے کس چیز پر توجہ دینی ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的模式保持私密。洞察只是帮助你看清接下来哪些事项值得关注。"
          }
        }
      }
    },
    "Your toDos already work locally.\n\nSign in if you'd like sync across devices, cloud backup, and future multi-platform access.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "المهام الخاصة بك تعمل بالفعل محليًا.\n\nقم بتسجيل الدخول إذا كنت ترغب في المزامنة عبر الأجهزة، والنسخ الاحتياطي السحابي، والوصول إلى منصات متعددة في المستقبل."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus tareas pendientes ya funcionan localmente.\n\nInicie sesión si desea sincronizar entre dispositivos, realizar copias de seguridad en la nube y acceder a múltiples plataformas en el futuro."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपके कार्य पहले से ही स्थानीय रूप से काम करते हैं।\n\nयदि आप सभी डिवाइसों में सिंक, क्लाउड बैकअप और भविष्य में मल्टी-प्लेटफ़ॉर्म एक्सेस चाहते हैं तो साइन इन करें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le tue cose da fare funzionano già a livello locale.\n\nAccedi se desideri la sincronizzazione tra dispositivi, il backup sul cloud e il futuro accesso multipiattaforma."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "あなたの ToDo はすでにローカルで機能しています。\n\nデバイス間での同期、クラウド バックアップ、将来のマルチプラットフォーム アクセスを希望する場合は、サインインしてください。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDos anda sudah berfungsi secara tempatan.\n\nLog masuk jika anda ingin menyegerak merentas peranti, sandaran awan dan akses berbilang platform pada masa hadapan."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "สิ่งที่ต้องทำของคุณใช้งานได้ภายในเครื่องแล้ว\n\nลงชื่อเข้าใช้หากคุณต้องการซิงค์ระหว่างอุปกรณ์ การสำรองข้อมูลบนคลาวด์ และการเข้าถึงหลายแพลตฟอร์มในอนาคต"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "آپ کے کام پہلے ہی مقامی طور پر کام کر رہے ہیں۔\n\nاگر آپ تمام آلات، کلاؤڈ بیک اپ، اور مستقبل میں ملٹی پلیٹ فارم تک رسائی حاصل کرنا چاہتے ہیں تو سائن ان کریں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您的待办事项已在本地运行。\n\n如果您想跨设备同步、云备份和未来的多平台访问，请登录。"
          }
        }
      }
    },
    "Your unsaved edits will be lost.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ستفقد تعديلاتك غير المحفوظة."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se perderán las ediciones no guardadas."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपके सहेजे न गए संपादन खो जाएंगे."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le modifiche non salvate andranno perse."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "未保存の編集は失われます。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Edit yang belum disimpan akan hilang."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การแก้ไขที่ยังไม่ได้บันทึกจะหายไป"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "آپ کی غیر محفوظ ترامیم ضائع ہو جائیں گی۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您未保存的编辑将会丢失。"
          }
        }
      }
    },

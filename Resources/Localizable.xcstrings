    "toDō is batching recent changes before sending them.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يقوم تُدُ بتجميع التغييرات الأخيرة قبل إرسالها."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō agrupa los cambios recientes antes de enviarlos."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō हाल के परिवर्तनों को भेजने से पहले उन्हें बैच रहा है।"
          }
        },
        "it": {

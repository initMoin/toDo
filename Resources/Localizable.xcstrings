    "Signed in and ready to keep iPhone, Android, and web in step.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم تسجيل الدخول وجاهز للاستمرار في متابعةiPhoneوAndroidوالويب."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ha iniciado sesión y está listo para manteneriPhone,Androidy la Web en sintonía."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "साइन इन किया गया है औरiPhone,Androidऔर वेब को क्रम में रखने के लिए तैयार है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Accedi e sei pronto per mantenereiPhone, ZXPLACEholder1ZX e il Web al passo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サインインし、iPhone、Android、および Web を連携させる準備ができました。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Log masuk dan bersedia untuk mengekalkaniPhone,Androiddan web dalam langkah."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ลงชื่อเข้าใช้แล้วและพร้อมที่จะให้iPhone,Androidและเว็บอยู่ในขั้นตอนต่อไป"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "سائن ان ہے اورiPhone،Android، اور ویب کو مرحلہ وار رکھنے کے لیے تیار ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已登录并准备好保持iPhone、Android和网络同步。"
          }
        }
      }
    },

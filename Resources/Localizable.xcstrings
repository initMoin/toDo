    "Write the task exactly how you think about it.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اكتب المهمة بالضبط كما تفكر فيها."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Escribe la tarea exactamente como piensas en ella."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कार्य को ठीक वैसे ही लिखें जैसे आप उसके बारे में सोचते हैं।"
          }
        },
        "it": {

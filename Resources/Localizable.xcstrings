            "state": "translated",
            "value": "Sync terakhir tidak selesai. %@%@"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การซิงก์ล่าสุดไม่เสร็จ %@%@"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "آخری sync مکمل نہیں ہوئی۔ %@%@"

            "value": "toDō sedang mengumpulkan perubahan terkini sebelum menghantarnya."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō กำลังรวบรวมการเปลี่ยนแปลงล่าสุดก่อนที่จะส่ง"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",

          "stringUnit": {
            "state": "translated",
            "value": "नए toDōs के लिए आपके खाते की जाँच की जा रही है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Controllo del tuo account per le attività da fare più recenti."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アカウントに新しい toDō がないか確認しています。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Menyemak akaun anda untuk toDō yang lebih baharu."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "กำลังตรวจสอบบัญชีของคุณสำหรับ toDōs ที่ใหม่กว่า"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "نئے ٹُڈُوز کے لیے آپ کا اکاؤنٹ چیک کیا جا رہا ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "检查您的帐户是否有更新的待办事项。"
          }
        }
      }
    },
    "Checks whether changes from another device can wake toDō.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتحقق مما إذا كانت التغييرات من جهاز آخر يمكنها إيقاظ تُدُ."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Comprueba si los cambios de otro dispositivo pueden activar toDō."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जांचता है कि दूसरे डिवाइस के बदलाव toDō को जगा सकते हैं या नहीं।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Controlla se le modifiche da un altro dispositivo possono riattivare toDō."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "別のデバイスの変更でtoDōを起動できるか確認します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Menyemak sama ada perubahan dari peranti lain boleh membangunkan toDō."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ตรวจว่าการเปลี่ยนจากอุปกรณ์อื่นปลุก toDō ได้หรือไม่"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "چیک کرتا ہے کہ دوسری ڈیوائس کی تبدیلیاں toDō کو جگا سکتی ہیں یا نہیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "检查其他设备的更改是否可以唤醒 toDō。"
          }
        }
      }
    },

    "Completed tasks can be archived for future reference.\n\nDeleted tasks are permanently removed.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يمكن أرشفة المهام المكتملة للرجوع إليها لاحقاً.\n\nالمهام المحذوفة تُزال نهائياً."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las tareas completadas se pueden archivar para consultarlas después.\n\nLas tareas eliminadas se quitan de forma permanente."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पूरे किए गए काम बाद में देखने के लिए आर्काइव किए जा सकते हैं.\n\nहटाए गए काम स्थायी रूप से मिटा दिए जाते हैं."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le attività completate possono essere archiviate per riferimento futuro.\n\nLe attività eliminate vengono rimosse definitivamente."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "完了したタスクは、あとで参照できるようにアーカイブできます。\n\n削除したタスクは完全に削除されます。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tugasan yang selesai boleh diarkibkan untuk rujukan kemudian.\n\nTugasan yang dipadam akan dibuang secara kekal."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "งานที่ทำเสร็จแล้วสามารถเก็บถาวรไว้ดูภายหลังได้\n\nงานที่ลบจะถูกนำออกถาวร"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "مکمل شدہ کام بعد میں دیکھنے کے لیے آرکائیو کیے جا سکتے ہیں۔\n\nحذف شدہ کام مستقل طور پر ہٹا دیے جاتے ہیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已完成的任务可以归档，方便以后查看。\n\n已删除的任务会被永久移除。"
          }
        }
      }
    },

    "Current timezone updates from your location when you refresh it.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تحديثات المنطقة الزمنية الحالية من موقعك عند تحديثها."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La zona horaria actual se actualiza desde su ubicación cuando la actualiza."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जब आप इसे रीफ्रेश करते हैं तो आपके स्थान से वर्तमान समयक्षेत्र अपडेट हो जाता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiornamenti del fuso orario corrente dalla tua posizione quando la aggiorni."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在地を更新すると、現在のタイムゾーンが現在地から更新されます。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Kemas kini zon waktu semasa dari lokasi anda apabila anda menyegarkannya."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เขตเวลาปัจจุบันจะอัปเดตจากตำแหน่งของคุณเมื่อคุณรีเฟรช"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "جب آپ اسے ریفریش کرتے ہیں تو آپ کے مقام سے موجودہ ٹائم زون اپ ڈیٹس۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当您刷新时，当前时区会根据您所在的位置进行更新。"
          }
        }
      }
    },
    "Customize how toDō behaves, syncs, and notifies you.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قم بتخصيص كيفية تصرفتُدُومزامنته وإعلامك."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Personalice cómo se comporta, sincroniza y notificatoDō."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अनुकूलित करें किtoDōआपको कैसे व्यवहार करता है, समन्वयित करता है और आपको सूचित करता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Personalizza il comportamento, la sincronizzazione e le notifiche ditoDō."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "toDōの動作、同期、通知の方法をカスタマイズします。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Sesuaikan caratoDōberkelakuan, menyegerak dan memberitahu anda."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",

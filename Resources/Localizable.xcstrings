            "value": "कोई भीtoDōइस दृश्य से मेल नहीं खाता।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nessun toDō corrisponde a questa vista."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この表示に一致するtoDōはありません。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tiada toDō sepadan dengan paparan ini."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ไม่มี toDō ที่ตรงกับมุมมองนี้"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "کوئی toDōs اس منظر سے مطابقت نہیں رکھتے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "没有toDō与此视图匹配。"

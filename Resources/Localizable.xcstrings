    "Sync needs review: %lld toDōs changed in two places.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "المزامنة تحتاج إلى مراجعة: تغيّرت %lld من تُدُس في مكانين."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La sincronización necesita revisión:%lldLas tareas pendientes cambiaron en dos lugares."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सिंक की समीक्षा की आवश्यकता है:%lldकार्य दो स्थानों पर बदले गए।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sincronizzazione da rivedere: %lld toDō sono cambiati in due punti."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "同期の確認が必要: %lld件のtoDōが2か所で変更されました。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Segerak perlu semakan: %lld toDō berubah di dua tempat."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ต้องตรวจสอบการซิงค์: toDō %lld รายการถูกเปลี่ยนในสองที่"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "سنک کو جائزے کی ضرورت ہے: %lld ٹُڈُوز دو جگہوں پر تبدیل ہوئے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "同步需要审核：%lldtoDōs 在两个地方发生了更改。"
          }
        }
      }
    },

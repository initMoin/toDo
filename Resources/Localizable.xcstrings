    "Allow alerts, sounds, notification actions, and time-sensitive delivery for due reminders.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "السماح بالتنبيهات والأصوات وإجراءات الإشعارات والتسليم الحساس للوقت للتذكيرات المستحقة."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Permita alertas, sonidos, acciones de notificación y entrega urgente para recordatorios vencidos."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "उचित अनुस्मारक के लिए अलर्ट, ध्वनियाँ, अधिसूचना क्रियाएँ और समय-संवेदनशील डिलीवरी की अनुमति दें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Consenti avvisi, suoni, azioni di notifica e consegna in tempi brevi per i promemoria dovuti."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アラート、サウンド、通知アクション、期限付きリマインダーの時間制限のある配信を許可します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Benarkan makluman, bunyi, tindakan pemberitahuan dan penghantaran sensitif masa untuk peringatan yang sewajarnya."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "อนุญาตการแจ้งเตือน เสียง การดำเนินการแจ้งเตือน และการจัดส่งตามเวลาสำหรับการแจ้งเตือนที่ครบกำหนด"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "انتباہات، آوازوں، اطلاع کی کارروائیوں، اور مناسب یاد دہانیوں کے لیے وقت کے لحاظ سے حساس ترسیل کی اجازت دیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "允许警报、声音、通知操作以及对到期提醒的时间敏感传递。"
          }
        }
      }
    },
    "Allow Always Location access so arrival and leaving reminders can work after ToDo is closed.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اسمح بالوصول الدائم للموقع كي تعمل تذكيرات الوصول والمغادرة بعد إغلاق تُدُ."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Permita el acceso a Siempre ubicación para que los recordatorios de llegada y salida puedan funcionar después de que se cierre ToDo."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हमेशा स्थान पहुंच की अनुमति दें ताकि आगमन और प्रस्थान अनुस्मारक ToDo बंद होने के बाद काम कर सकें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Consenti sempre l'accesso alla posizione in modo che i promemoria di arrivo e partenza possano funzionare dopo la chiusura di ToDo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo が閉じられた後でも到着と出発のリマインダーが機能できるように、常に位置情報へのアクセスを許可します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Benarkan akses Lokasi Sentiasa supaya peringatan ketibaan dan keluar boleh berfungsi selepas Tugasan ditutup."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "อนุญาตการเข้าถึงตำแหน่งเสมอ เพื่อให้การเตือนเมื่อมาถึงและออกจากสามารถทำงานได้หลังจากปิด ToDo"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ہمیشہ مقام تک رسائی دیں تاکہ ٹُڈُو بند ہونے کے بعد آمد اور روانگی کی یاد دہانیاں کام کریں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "允许“始终位置”访问，以便在待办事项关闭后可以使用到达和离开提醒。"
          }
        }
      }
    },

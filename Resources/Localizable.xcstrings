    "toDō couldn’t add this nanoDo. %@": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذر على تُدُ إضافة هذا النانو دُ. %@"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō no pudo agregar este nanoDo. %@"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō इस nanoDo को जोड़ नहीं सका। %@"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō non ha potuto aggiungere questo nanoDo. %@"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "toDōはこのnanoDoを追加できませんでした。%@"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō tidak dapat menambah nanoDo ini. %@"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō ไม่สามารถเพิ่ม nanoDo นี้ได้ %@"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō یہ nanoDo شامل نہیں کر سکا۔ %@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō 无法添加此 nanoDo。%@"
          }
        }
      }
    },

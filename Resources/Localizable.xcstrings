    "ToDo can notify you when you arrive at or leave a saved location.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يمكن لـ تُدُ تنبيهك عند وصولك إلى موقع محفوظ أو مغادرتك له."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo puede notificarle cuando llega o sale de una ubicación guardada."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जब आप किसी सहेजे गए स्थान पर पहुंचते हैं या निकलते हैं तो ToDo आपको सूचित कर सकता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo può avvisarti quando arrivi o lasci un luogo salvato."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "保存した場所に到着または出発したときにToDoが通知できます。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo boleh memaklumkan anda apabila tiba atau meninggalkan lokasi yang disimpan."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo สามารถแจ้งเตือนเมื่อคุณมาถึงหรือออกจากตำแหน่งที่บันทึกไว้"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ٹُڈُو آپ کو محفوظ مقام پر پہنچنے یا وہاں سے نکلنے پر اطلاع دے سکتا ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当您到达或离开保存的位置时，ToDo 可以通知您。"
          }
        }
      }
    },
    "toDō can remind you when tasks become important.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يمكن لـتُدُأن يذكرك عندما تصبح المهام مهمة."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "toDōpuede recordarle cuando las tareas se vuelven importantes."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जब कार्य महत्वपूर्ण हो जाते हैं तोtoDōआपको याद दिला सकता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "ZXPLACEholder0ZX può ricordarti quando le attività diventano importanti."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "toDōは、タスクが重要になったときに通知できます。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "toDōboleh mengingatkan anda apabila tugas menjadi penting."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "toDōสามารถเตือนคุณเมื่องานกลายเป็นเรื่องสำคัญ"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "جب کام اہم ہو جائیں توٹُڈُوآپ کو یاد دلا سکتا ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō可以在任务变得重要时提醒您。"
          }
        }
      }
    },

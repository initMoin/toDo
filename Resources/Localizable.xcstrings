    "Capture something important. A task, reminder, responsibility, or idea.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "التقاط شيء مهم. مهمة أو تذكير أو مسؤولية أو فكرة."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Captura algo importante. Una tarea, recordatorio, responsabilidad o idea."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कोई महत्वपूर्ण चीज़ कैप्चर करें. कोई कार्य, अनुस्मारक, जिम्मेदारी, या विचार।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Cattura qualcosa di importante. Un compito, un promemoria, una responsabilità o un'idea."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "大切なものを捉えます。タスク、リマインダー、責任、またはアイデア。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tangkap sesuatu yang penting. Tugas, peringatan, tanggungjawab atau idea."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "จับภาพบางสิ่งที่สำคัญ งาน สิ่งเตือนใจ ความรับผิดชอบ หรือแนวคิด"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "کسی اہم چیز کو پکڑیں۔ ایک کام، یاد دہانی، ذمہ داری، یا خیال۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "捕捉重要的东西。任务、提醒、责任或想法。"
          }
        }
      }
    },
    "Capture still works when your iPhone is nearby.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يزال الالتقاط يعمل عندما يكون iPhone قريبًا."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Capturar sigue funcionando cuando tu iPhone está cerca."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपका iPhone पास हो तो कैप्चर अब भी काम करता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L’acquisizione funziona ancora quando l’iPhone è vicino."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iPhoneが近くにあればキャプチャは引き続き使えます。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tangkap masih berfungsi apabila iPhone anda berdekatan."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ยังบันทึกได้เมื่อ iPhone อยู่ใกล้ ๆ"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "جب آپ کا iPhone قریب ہو تو capture اب بھی کام کرتا ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",

            "state": "translated",
            "value": "यह चयनित toDō को हटा देता है."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rimuove il toDō selezionato."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択したtoDōを削除します。"
          }
        },
        "ms": {

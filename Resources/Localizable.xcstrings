    "Completed tasks can be archived for future reference.\n\nDeleted tasks are permanently removed.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يمكن أرشفة المهام المكتملة للرجوع إليها في المستقبل.\n\nتتم إزالة المهام المحذوفة بشكل دائم."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las tareas completadas se pueden archivar para referencia futura.\n\nLas tareas eliminadas se eliminan permanentemente."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पूर्ण किए गए कार्यों को भविष्य के संदर्भ के लिए संग्रहीत किया जा सकता है।\n\nहटाए गए कार्य स्थायी रूप से हटा दिए जाते हैं."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le attività completate possono essere archiviate per riferimento futuro.\n\nLe attività eliminate vengono rimosse in modo permanente."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "完了したタスクは、後で参照できるようにアーカイブできます。\n\n削除されたタスクは完全に削除されます。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tugasan yang telah siap boleh diarkibkan untuk rujukan masa hadapan.\n\nTugasan yang dipadamkan dialih keluar secara kekal."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "งานที่เสร็จสมบูรณ์สามารถเก็บถาวรเพื่อใช้อ้างอิงในอนาคต\n\nงานที่ลบจะถูกลบออกอย่างถาวร"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "مکمل شدہ کاموں کو مستقبل کے حوالے کے لیے محفوظ کیا جا سکتا ہے۔\n\nحذف شدہ کاموں کو مستقل طور پر ہٹا دیا جاتا ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已完成的任务可以存档以供将来参考。\n\n已删除的任务将被永久删除。"
          }
        }
      }
    },

        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Menyemak akaun anda untuk ToDo yang lebih baharu."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "กำลังตรวจสอบบัญชีของคุณสำหรับ ToDos ที่ใหม่กว่า"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "نئے ٹُڈُوز کے لیے آپ کا اکاؤنٹ چیک کیا جا رہا ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "检查您的帐户是否有更新的待办事项。"
          }
        }
      }
    },
    "Choose the category this widget should show.": {
      "localizations": {

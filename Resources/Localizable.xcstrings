    "%lld toDōs changed in two places. Choose which versions to keep.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تغيّرت %lld من تُدُس في مكانين. اختر الإصدارات التي تريد الاحتفاظ بها."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%lldLas tareas pendientes cambiaron en dos lugares. Elija qué versiones conservar."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%lldकार्य दो स्थानों पर बदले गए। चुनें कि कौन से संस्करण रखना है."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld toDō sono cambiati in due punti. Scegli quali versioni mantenere."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld件のtoDōが2か所で変更されました。残すバージョンを選んでください。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld toDō berubah di dua tempat. Pilih versi yang mahu disimpan."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō %lld รายการถูกเปลี่ยนในสองที่ เลือกเวอร์ชันที่จะเก็บไว้"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld ٹُڈُوز دو جگہوں پر تبدیل ہوئے۔ منتخب کریں کہ کون سے ورژنز رکھنے ہیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%lldtoDōs 在两个地方发生了变化。选择要保留的版本。"
          }
        }
      }
    },

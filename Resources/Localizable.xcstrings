    "Re-fetch your Supabase profile and session-backed account state.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إعادة جلب ملف Supabase الشخصي وحالة الحساب المدعومة بالجلسة."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Vuelva a buscar su perfilSupabasey el estado de su cuenta respaldada por sesión."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपनीSupabaseप्रोफ़ाइल और सत्र-समर्थित खाता स्थिति पुनः प्राप्त करें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Recupera di nuovo il profilo Supabase e lo stato account della sessione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Supabaseプロフィールとセッションに基づくアカウント状態を再取得します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Dapatkan semula profil Supabase dan keadaan akaun bersandarkan sesi."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ดึงโปรไฟล์ Supabase และสถานะบัญชีจากเซสชันอีกครั้ง"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اپنا Supabase پروفائل اور سیشن پر مبنی اکاؤنٹ حالت دوبارہ حاصل کریں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "重新获取您的Supabase配置文件和会话支持的帐户状态。"
          }
        }
      }
    },
    "Re-register for push notifications, refresh scheduled reminders, and re-check time-sensitive delivery.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أعد التسجيل للحصول على إشعارات الدفع، وقم بتحديث التذكيرات المجدولة، وأعد التحقق من التسليم الحساس للوقت."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Vuelva a registrarse para recibir notificaciones automáticas, actualice los recordatorios programados y vuelva a verificar la entrega urgente."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पुश सूचनाओं के लिए पुनः पंजीकरण करें, निर्धारित अनुस्मारक ताज़ा करें, और समय-संवेदनशील डिलीवरी की पुनः जाँच करें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Registrati nuovamente per ricevere notifiche push, aggiorna i promemoria programmati e ricontrolla la consegna urgente."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プッシュ通知を再登録し、スケジュールされたリマインダーを更新し、時間制限のある配信を再確認します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Daftar semula untuk pemberitahuan tolak, muat semula peringatan berjadual dan semak semula penghantaran sensitif masa."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ลงทะเบียนใหม่เพื่อรับการแจ้งเตือนแบบพุช รีเฟรชการแจ้งเตือนตามกำหนดเวลา และตรวจสอบการจัดส่งตามเวลาอีกครั้ง"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "پش نوٹیفیکیشنز کے لیے دوبارہ رجسٹر کریں، شیڈول کردہ یاد دہانیوں کو ریفریش کریں، اور وقت کے لحاظ سے حساس ڈیلیوری کو دوبارہ چیک کریں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",

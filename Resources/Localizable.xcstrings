    "No account required. toDō will stay on this device.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يلزم حساب. سيبقى تُدُ على هذا الجهاز."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No hace falta cuenta. toDō se quedara en este dispositivo."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "खाते की जरूरत नहीं। toDō इस डिवाइस पर रहेगा।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nessun account richiesto. toDō restera su questo dispositivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アカウントは不要です。toDōはこのデバイスに残ります。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tiada akaun diperlukan. toDō akan kekal pada peranti ini."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ไม่ต้องมีบัญชี toDō จะอยู่บนอุปกรณ์นี้"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اکاؤنٹ کی ضرورت نہیں۔ toDō اسی ڈیوائس پر رہے گا۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无需帐户。toDō 会保留在此设备上。"
          }
        }
      }
    },

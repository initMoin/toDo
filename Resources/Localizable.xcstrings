    "Use Google's native sign-in flow to connect ToDo Sync.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدم مسار تسجيل الدخول الأصلي من Google للاتصال بـ مزامنة تُدُ."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilice el flujo de inicio de sesión nativo deGooglepara conectar ToDo Sync."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo Sync को कनेक्ट करने के लिएGoogleके मूल साइन-इन प्रवाह का उपयोग करें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa il flusso di accesso nativo di Google per collegare ToDo Sync."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "GoogleのネイティブサインインでToDo Syncに接続します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Gunakan aliran daftar masuk asli Google untuk menyambungkan ToDo Sync."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ใช้ขั้นตอนลงชื่อเข้าใช้ของ Google เพื่อเชื่อมต่อ ToDo Sync"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ٹُڈُو سنک جوڑنے کے لیے Google کا native سائن ان فلو استعمال کریں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用Google的本机登录流程连接 ToDo Sync。"
          }
        }
      }
    },
    "Use Sync with iCloud for Apple-only devices. Use ToDo Sync when you also want Android or web access.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدم المزامنة مع iCloud للأجهزة التي تعمل بنظام Apple فقط. استخدم مزامنة تُدُ عندما تريد أيضًا الوصول من Android أو الويب."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilice Sincronización coniCloudpara dispositivos soloApple. Utilice ToDo Sync cuando también deseeAndroido acceso web."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "केवलAppleउपकरणों के लिएiCloudके साथ सिंक का उपयोग करें। जब आपAndroidया वेब एक्सेस भी चाहते हों तो ToDo Sync का उपयोग करें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa Sincronizza con iCloud per soli dispositivi Apple. Usa ToDo Sync se vuoi anche accesso Android o web."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "AppleデバイスだけならiCloud同期を使います。AndroidやWebでも使うならToDo Syncを使います。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Gunakan Segerak dengan iCloud untuk peranti Apple sahaja. Gunakan ToDo Sync jika anda juga mahu akses Android atau web."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ใช้การซิงค์กับ iCloud สำหรับอุปกรณ์ Apple เท่านั้น ใช้ ToDo Sync หากต้องการเข้าถึง Android หรือเว็บด้วย"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "صرف Apple ڈیوائسز کے لیے iCloud کے ساتھ سنک استعمال کریں۔ جب Android یا ویب رسائی بھی چاہیے ہو تو ٹُڈُو سنک استعمال کریں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "对于仅限Apple的设备，使用与iCloud同步。当您还需要Android或 Web 访问时，请使用 ToDo Sync。"
          }
        }
      }
    },
    "Use Synced": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدام المتزامن"
          }
        },
        "es": {

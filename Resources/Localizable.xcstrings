    "Open system Settings to allow notifications for ToDo.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "افتح إعدادات النظام للسماح بإشعارات تُدُ."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Abra la Configuración del sistema para permitir notificaciones de tareas pendientes."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo के लिए सूचनाओं की अनुमति देने के लिए सिस्टम सेटिंग्स खोलें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Apri le Impostazioni di sistema per consentire le notifiche per ToDo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "システム設定を開き、ToDo の通知を許可します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Buka Tetapan sistem untuk membenarkan pemberitahuan untuk Tugasan."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เปิดการตั้งค่าระบบเพื่ออนุญาตการแจ้งเตือนสำหรับสิ่งที่ต้องทำ"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ٹُڈُو کے لیے اطلاعات کی اجازت دینے کے لیے سسٹم کی ترتیبات کھولیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打开系统设置以允许 ToDo 通知。"
          }
        }
      }
    },

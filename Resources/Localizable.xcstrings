    },
    "%@ completed in the last 7 days.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ أُنجز خلال آخر ٧ أيام."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ completados en los últimos 7 días."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पिछले 7 दिनों में %@ पूर्ण।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ completati negli ultimi 7 giorni."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "過去7日間に %@ 件完了。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ selesai dalam 7 hari lalu."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ รายการเสร็จใน 7 วันที่ผ่านมา"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "گزشتہ ۷ دن میں %@ مکمل۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "过去 7 天完成 %@ 个。"
          }
        }
      }
    },
    "%@ days left": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "باقي %@ يوم"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Quedan %@ días"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ दिन बचे हैं"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ giorni rimasti"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "残り%@日"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ hari lagi"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เหลือ %@ วัน"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ دن باقی ہیں"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "还剩 %@ 天"
          }
        }
      }
    },
    "%@ deletes synced.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تمت مزامنة %@ عمليات حذف."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ eliminaciones sincronizadas."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ हटाने सिंक हुए."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ eliminazioni sincronizzate."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@件の削除を同期しました。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ pemadaman disegerakkan."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ซิงค์การลบ %@ รายการแล้ว"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ حذف شدہ آئٹمز سنک ہو گئے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已同步 %@ 次删除。"
          }
        }
      }
    },
    "%@ Due reminders can play a sound and show quick actions.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ يمكن لتذكيرات الاستحقاق تشغيل صوت وعرض إجراءات سريعة."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ Los recordatorios con fecha pueden reproducir sonido y mostrar acciones rapidas."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ देय रिमाइंडर ध्वनि चला सकते हैं और त्वरित कार्रवाइयां दिखा सकते हैं।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ I promemoria in scadenza possono riprodurre un suono e mostrare azioni rapide."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 期限リマインダーはサウンドを鳴らし、クイック操作を表示できます。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ Peringatan perlu dibuat boleh memainkan bunyi dan menunjukkan tindakan pantas."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ การเตือนครบกำหนดสามารถเล่นเสียงและแสดงการทำงานด่วนได้"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ واجب یاد دہانیاں آواز چلا سکتی ہیں اور فوری اقدامات دکھا سکتی ہیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 到期提醒可以播放声音并显示快捷操作。"
          }
        }
      }
    },
    "%@ due today.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ مستحق اليوم."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ vencen hoy."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ आज देय।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ in scadenza oggi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 件が今日期限。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ perlu dibuat hari ini."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ รายการครบกำหนดวันนี้"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ آج واجب۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 个今天到期。"
          }
        }
      }
    },
    "%@ incomplete toDōs": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ تُدُس غير مكتملة"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ toDōs incompletos"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ अधूरे toDō"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ toDō incompleti"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 件の未完了toDō"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ toDō belum selesai"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō ยังไม่เสร็จ %@ รายการ"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ نامکمل تُدُس"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 个未完成 toDō"
          }
        }
      }
    },
    "%@ is not available on this build of toDō.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ غير متاح في هذا الإصدار من toDō."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ no está disponible en esta compilación de toDō."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ toDō के इस बिल्ड में उपलब्ध नहीं है."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ non è disponibile in questa build di toDō."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@はこのtoDōビルドでは利用できません。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ tidak tersedia pada binaan toDō ini."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ ไม่พร้อมใช้งานในบิลด์ toDō นี้"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ toDō کے اس بلڈ میں دستیاب نہیں ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 在此 toDō 构建中不可用。"
          }
        }
      }
    },
    "%@ is saved. Close and reopen toDō when you are ready to use it.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم حفظ %@. أغلق تُدُ وأعد فتحه عندما تكون جاهزًا لاستخدامه."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ se guardo. Cierra y vuelve a abrir toDō cuando quieras usarlo."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ सहेजा गया है। इसे इस्तेमाल करने के लिए तैयार हों तो toDō बंद करके फिर खोलें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ e salvato. Chiudi e riapri toDō quando vuoi usarlo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ を保存しました。使う準備ができたらtoDōを閉じて開き直してください。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ disimpan. Tutup dan buka semula toDō apabila sedia menggunakannya."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "บันทึก %@ แล้ว ปิดและเปิด toDō ใหม่เมื่อพร้อมใช้งาน"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ محفوظ ہو گیا ہے۔ استعمال کے لیے تیار ہوں تو toDō بند کر کے دوبارہ کھولیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 已保存。准备使用时，请关闭并重新打开 toDō。"
          }
        }
      }
    },
    "%@ is selected, but you still need to sign in. Until then, toDōs stay on this device.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم تحديد %@، لكن ما زال عليك تسجيل الدخول. إلى ذلك الحين، ستبقى تُدُس على هذا الجهاز."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ esta seleccionado, pero aun debes iniciar sesion. Hasta entonces, tus toDōs quedan en este dispositivo."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ चुना गया है, लेकिन आपको अभी साइन इन करना होगा। तब तक toDōs इसी डिवाइस पर रहेंगे।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ e selezionato, ma devi ancora accedere. Fino ad allora, i toDō restano su questo dispositivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ が選択されていますが、サインインが必要です。それまではtoDōはこのデバイスに残ります。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ dipilih, tetapi anda masih perlu daftar masuk. Sehingga itu, toDō kekal pada peranti ini."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เลือก %@ แล้ว แต่ยังต้องลงชื่อเข้าใช้ ก่อนถึงตอนนั้น toDō จะอยู่บนอุปกรณ์นี้"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ منتخب ہے، مگر آپ کو ابھی سائن ان کرنا ہوگا۔ تب تک toDōs اسی ڈیوائس پر رہیں گے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已选择 %@，但你仍需登录。在此之前，toDō 会保留在此设备上。"
          }
        }
      }
    },
    "%@ is selected. Sign in below to turn it on; until then, toDō stays with %@.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم تحديد %@. سجّل الدخول أدناه لتشغيله؛ إلى ذلك الحين، سيبقى تُدُ مع %@."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ is selected. Sign in below to turn it on; until then, toDō stays with %2$@."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ esta seleccionado. Inicia sesion abajo para activarlo; hasta entonces, toDō sigue con %@."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ चुना गया है। इसे चालू करने के लिए नीचे साइन इन करें; तब तक toDō %@ के साथ रहेगा।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ e selezionato. Accedi qui sotto per attivarlo; fino ad allora, toDō resta con %@."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",

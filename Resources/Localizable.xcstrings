    "1 toDō changed in two places. Choose which version to keep.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تغيّر تُدُ واحد في مكانين. اختر الإصدار الذي تريد الاحتفاظ به."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "1 toDō cambió en dos lugares. Elija qué versión conservar."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "1 टूडू दो स्थानों पर बदला गया। चुनें कि कौन सा संस्करण रखना है."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "1 toDō è cambiato in due punti. Scegli quale versione mantenere."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "1件のtoDōが2か所で変更されました。残すバージョンを選んでください。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "1 toDō berubah di dua tempat. Pilih versi yang mahu disimpan."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō 1 รายการถูกเปลี่ยนในสองที่ เลือกเวอร์ชันที่จะเก็บไว้"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ایک ٹُڈُو دو جگہوں پر تبدیل ہوا۔ منتخب کریں کہ کون سا ورژن رکھنا ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {

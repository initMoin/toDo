            "value": "I tuoi tag"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "あなたのタグ"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tag anda"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "แท็กของคุณ"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "آپ کے ٹیگز"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的标签"
          }
        }
      }
    },
    "Your toDō": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تُدُ الخاص بك"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu toDō"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपका toDō"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tuo toDō"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "あなたのtoDō"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō anda"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō ของคุณ"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "آپ کا ٹُڈُو"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的 toDō"
          }
        }
      }
    },
    "Your toDōs already work on this device.\n\nChoose iCloud for Apple-only sync, toDō Sync for account-based cross-platform sync, or stay local if you prefer no remote copy.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعمل تُدُس لديك بالفعل على هذا الجهاز.\n\nاختر iCloud للمزامنة بين أجهزة Apple فقط، أو مزامنة تُدُ للمزامنة عبر الحساب بين المنصات، أو ابق محلياً إذا كنت لا تريد نسخة بعيدة."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus toDōs ya funcionan en este dispositivo.\n\nElige iCloud para sincronizar solo entre dispositivos Apple, toDō Sync para sincronización multiplataforma con cuenta, o mantén todo local si prefieres no tener copia remota."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपके toDōs इस डिवाइस पर पहले से काम करते हैं.\n\niCloud चुनें अगर केवल Apple डिवाइसों में सिंक चाहिए, खाते-आधारित क्रॉस-प्लैटफ़ॉर्म सिंक के लिए toDō Sync चुनें, या रिमोट कॉपी नहीं चाहिए तो लोकल रहें."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I tuoi toDō funzionano già su questo dispositivo.\n\nScegli iCloud per la sincronizzazione solo tra dispositivi Apple, toDō Sync per la sincronizzazione multipiattaforma basata su account, oppure resta in locale se preferisci non avere una copia remota."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "あなたのtoDōはこのデバイスですでに使えます。\n\nAppleデバイスだけで同期するならiCloud、アカウントベースでクロスプラットフォーム同期するならtoDō Sync、リモートコピーを持ちたくない場合はローカルのままにします。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō anda sudah berfungsi pada peranti ini.\n\nPilih iCloud untuk penyegerakan Apple sahaja, toDō Sync untuk penyegerakan merentas platform berasaskan akaun, atau kekal setempat jika anda tidak mahu salinan jauh."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō ของคุณใช้งานได้บนอุปกรณ์นี้แล้ว\n\nเลือก iCloud สำหรับซิงก์เฉพาะอุปกรณ์ Apple, เลือก toDō Sync สำหรับซิงก์ข้ามแพลตฟอร์มผ่านบัญชี หรือเก็บไว้ในเครื่องถ้าไม่ต้องการสำเนาระยะไกล"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "آپ کے toDōs اس ڈیوائس پر پہلے ہی کام کرتے ہیں۔\n\nصرف Apple ڈیوائسز کے لیے iCloud منتخب کریں، اکاؤنٹ پر مبنی کراس پلیٹ فارم سنک کے لیے toDō Sync منتخب کریں، یا اگر ریموٹ کاپی نہیں چاہیے تو مقامی رہیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的 toDō 已经可以在此设备上使用。\n\n如果只在 Apple 设备间同步，请选择 iCloud；如果需要基于账户的跨平台同步，请选择 toDō Sync；如果不想保留远程副本，可以继续仅保存在本机。"
          }
        }
      }
    },
    "Your toDōs stay on this device until you choose a sync option.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تبقى تُدُس على هذا الجهاز حتى تختار خيار مزامنة."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus toDōs se quedan en este dispositivo hasta que elijas una opcion de sync."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जब तक आप सिंक विकल्प नहीं चुनते, आपके toDōs इसी डिवाइस पर रहते हैं।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I tuoi toDō restano su questo dispositivo finche non scegli un'opzione di sync."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "同期オプションを選ぶまで、toDōはこのデバイスに残ります。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō anda kekal pada peranti ini sehingga anda memilih pilihan sync."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō จะอยู่บนอุปกรณ์นี้จนกว่าคุณจะเลือกตัวเลือกซิงก์"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "Sync option منتخب کرنے تک آپ کے toDōs اسی ڈیوائس پر رہتے ہیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在你选择同步选项前，toDō 会保留在此设备上。"
          }
        }
      }
    },
    "Your unsaved edits will be lost.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ستفقد تعديلاتك غير المحفوظة."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se perderán las ediciones no guardadas."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपके सहेजे न गए संपादन खो जाएंगे."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le modifiche non salvate andranno perse."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "未保存の編集は失われます。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Edit yang belum disimpan akan hilang."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การแก้ไขที่ยังไม่ได้บันทึกจะหายไป"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "آپ کی غیر محفوظ ترامیم ضائع ہو جائیں گی۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您未保存的编辑将会丢失。"
          }
        }
      }
    },

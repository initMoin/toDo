    "toDō Sync is keeping your toDōs available across your signed-in devices.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تحافظ مزامنة تُدُ على توفر تُدُس عبر أجهزتك التي سجّلت الدخول إليها."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō Sync mantiene tus toDōs disponibles en tus dispositivos conectados."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō Sync आपके साइन-इन डिवाइसों पर आपके toDōs उपलब्ध रखता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō Sync mantiene disponibili i tuoi toDō sui dispositivi su cui hai effettuato l'accesso."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō Syncはサインイン中のデバイスでtoDōを使えるようにします。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō Sync memastikan toDō anda tersedia pada peranti yang didaftar masuk."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō Sync ทำให้ toDō ใช้ได้บนอุปกรณ์ที่ลงชื่อเข้าใช้"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō Sync آپ کے signed-in ڈیوائسز پر toDōs دستیاب رکھتا ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō Sync 会让你的 toDō 在已登录设备上可用。"
          }
        }
      }
    },

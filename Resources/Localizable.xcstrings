    "If you do nothing here, ToDo keeps running locally on this device path.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إذا لم تفعل شيئًا هنا، سيستمر تُدُ في العمل محليًا على مسار هذا الجهاز."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si no hace nada aquí, ToDo sigue ejecutándose localmente en esta ruta del dispositivo."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यदि आप यहां कुछ नहीं करते हैं, तो ToDo इस डिवाइस पथ पर स्थानीय रूप से चलता रहता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Se non fai nulla qui, ToDo continua a funzionare localmente su questo dispositivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ここで何もしない場合、ToDoはこのデバイスでローカルに動作し続けます。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Jika anda tidak melakukan apa-apa di sini, ToDo terus berjalan secara tempatan pada peranti ini."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "หากไม่ทำอะไร ToDo จะทำงานในเครื่องบนอุปกรณ์นี้ต่อไป"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اگر آپ یہاں کچھ نہ کریں تو ٹُڈُو اس ڈیوائس کے مقامی راستے پر چلتا رہے گا۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如果您在此处不执行任何操作，ToDo 将继续在此设备路径上本地运行。"
          }
        }
      }
    },

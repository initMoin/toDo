    },
    "You're caught up. Nothing needs urgent attention right now.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أنت على المسار الصحيح. لا شيء يحتاج إلى انتباه عاجل الآن."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Estás al día. Nada necesita atención urgente ahora mismo."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आप अभी संभले हुए हैं। अभी किसी चीज़ पर तुरंत ध्यान देने की ज़रूरत नहीं है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sei in pari. Nulla richiede attenzione urgente in questo momento."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今は順調です。すぐに対応が必要なものはありません。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Anda sudah terkawal. Tiada apa-apa yang perlukan perhatian segera sekarang."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ตอนนี้คุณตามทันแล้ว ไม่มีอะไรต้องรีบจัดการทันที"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "آپ ابھی سنبھلے ہوئے ہیں۔ اس وقت کسی چیز کو فوری توجہ کی ضرورت نہیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你现在已经跟上了。暂时没有需要紧急处理的事项。"
          }
        }
      }
    },
    "You're ready.": {
      "localizations": {

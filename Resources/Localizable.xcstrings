    "Tests a passive notification that should avoid sound.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يختبر إشعارًا هادئًا يجب أن يتجنب الصوت."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Prueba una notificación pasiva que no debería sonar."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक निष्क्रिय सूचना का परीक्षण करता है जिसे ध्वनि से बचना चाहिए."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Testa una notifica passiva che non dovrebbe emettere suoni."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "音を鳴らさないパッシブ通知をテストします。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Menguji pemberitahuan pasif yang tidak sepatutnya berbunyi."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ทดสอบการแจ้งเตือนแบบเงียบที่ไม่ควรมีเสียง"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ایک غیر فعال اطلاع کو جانچتا ہے جس میں آواز نہیں ہونی چاہیے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "测试应避免声音的被动通知。"
          }
        }
      }
    },

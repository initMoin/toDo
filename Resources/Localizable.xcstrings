    "Adopt local ToDos into ToDo Sync for cross-platform access.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اعتماد تُدُس المحلية في تُدُ Sync للوصول عبر الأنظمة الأساسية."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Adopte tareas pendientes locales en ToDo Sync para obtener acceso multiplataforma."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "क्रॉस-प्लेटफ़ॉर्म पहुंच के लिए स्थानीय ToDos को ToDo Sync में अपनाएं।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Adotta le attività ToDo locali in ToDo Sync per l'accesso multipiattaforma."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ローカル ToDo を ToDo Sync に採用して、クロスプラットフォーム アクセスを実現します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Gunakan ToDos tempatan ke dalam ToDo Sync untuk akses merentas platform."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "นำ ToDos ภายในมาใช้ใน ToDo Sync เพื่อการเข้าถึงข้ามแพลตฟอร์ม"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "کراس پلیٹ فارم تک رسائی کے لیے مقامی ٹُڈُوز کو ٹُڈُو Sync میں اپنائیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将本地 ToDo 纳入 ToDo Sync 中以实现跨平台访问。"
          }
        }
      }
    },
    "Alerts that the ToDo has reached its due moment.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تنبيهات بأن المهام قد وصلت إلى وقتها المحدد."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Alerta que el ToDo ha llegado a su debido momento."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सचेत करता है कि टूडू अपने नियत समय पर पहुंच गया है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Avvisa che l'attività ToDo è giunta al momento opportuno."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo が期限に達したことを警告します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Makluman bahawa Tugasan telah mencapai masa yang sepatutnya."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "แจ้งเตือนว่า ToDo ถึงเวลาครบกำหนดแล้ว"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "انتباہات کہ ٹُڈُو اپنے مقررہ وقت پر پہنچ گیا ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "提醒待办事项已到达指定时间。"
          }
        }
      }
    },

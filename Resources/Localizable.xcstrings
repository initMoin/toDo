    "Move your ToDo Sync data into iCloud sync for Apple-only use.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "انقل بيانات تُدُ Sync إلى مزامنةiCloudلاستخدامAppleفقط."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mueva sus datos de ToDo Sync a la sincronizacióniCloudpara uso exclusivo deApple."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "केवलAppleके उपयोग के लिए अपने ToDo सिंक डेटा कोiCloudसिंक में ले जाएं।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sposta i tuoi dati ToDo Sync nella sincronizzazioneiCloudper l'uso esclusivo conApple."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Appleのみで使用するために、ToDo 同期データをiCloud同期に移動します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Alihkan data Penyegerakan Tugasan anda ke penyegerakaniClouduntuk kegunaanApplesahaja."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ย้ายข้อมูล ToDo Sync ของคุณไปยังการซิงค์iCloudสำหรับApple- ใช้เท่านั้น"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اپنے ٹُڈُو Sync ڈیٹا کوiCloudسنک میںApple- صرف استعمال کے لیے منتقل کریں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将您的 ToDo 同步数据移至iCloud同步中，仅供Apple使用。"
          }
        }
      }
    },

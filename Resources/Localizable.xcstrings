            "value": "بعض تُدُس النشطة لم تتحرك منذ أكثر من أسبوعين."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Algunos ToDos activos no se han movido en más de dos semanas."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कुछ सक्रिय ToDos दो सप्ताह से अधिक समय से आगे नहीं बढ़े हैं।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Alcuni ToDo attivi non si muovono da oltre due settimane."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "一部のアクティブ ToDos は2週間以上動いていません。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Beberapa ToDos aktif tidak bergerak selama lebih dua minggu."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDos ที่ใช้งานอยู่บางรายการไม่มีความคืบหน้ามากกว่าสองสัปดาห์"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "کچھ فعال تُدُس دو ہفتوں سے زیادہ عرصے سے آگے نہیں بڑھے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一些活动 ToDos 已超过两周没有进展。"
          }
        }
      }
    },

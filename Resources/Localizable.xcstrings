    "ToDo Sync is selected, but this device is still using %@ until you sign in.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم تحديد تُدُ Sync، لكن هذا الجهاز لا يزال يستخدم%@حتى تقوم بتسجيل الدخول."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo Sync está seleccionado, pero este dispositivo sigue usando%@hasta que inicies sesión."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "टूडू सिंक चयनित है, लेकिन जब तक आप साइन इन नहीं करते तब तक यह डिवाइस अभी भी%@का उपयोग कर रहा है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo Sync è selezionato, ma questo dispositivo utilizza ancora%@finché non accedi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo Sync が選択されていますが、このデバイスはサインインするまで%@を使用したままになります。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo Sync dipilih, tetapi peranti ini masih menggunakan%@sehingga anda log masuk."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เลือก ToDo Sync แล้ว แต่อุปกรณ์นี้ยังคงใช้%@จนกว่าคุณจะลงชื่อเข้าใช้"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ٹُڈُو Sync کو منتخب کیا گیا ہے، لیکن یہ آلہ اب بھی%@استعمال کر رہا ہے جب تک آپ سائن ان نہیں کرتے ہیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo Sync 已选择，但在您登录之前此设备仍在使用%@。"
          }
        }
      }
    },

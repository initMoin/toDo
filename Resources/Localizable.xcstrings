    "%lld ToDos changed in two places. Choose which versions to keep.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تغيّرت %lld من تُدُس في مكانين. اختر الإصدارات التي تريد الاحتفاظ بها."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%lldLas tareas pendientes cambiaron en dos lugares. Elija qué versiones conservar."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%lldकार्य दो स्थानों पर बदले गए। चुनें कि कौन से संस्करण रखना है."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld ToDo sono cambiati in due punti. Scegli quali versioni mantenere."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld件のToDoが2か所で変更されました。残すバージョンを選んでください。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld ToDo berubah di dua tempat. Pilih versi yang mahu disimpan."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo %lld รายการถูกเปลี่ยนในสองที่ เลือกเวอร์ชันที่จะเก็บไว้"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld ٹُڈُوز دو جگہوں پر تبدیل ہوئے۔ منتخب کریں کہ کون سے ورژنز رکھنے ہیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%lldToDos 在两个地方发生了变化。选择要保留的版本。"
          }
        }
      }
    },
    "%lld unused tag(s) will be permanently removed.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ستتم إزالة %lld وسم غير مستخدم نهائيًا."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las etiquetas%lldno utilizadas se eliminarán permanentemente."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%lldअप्रयुक्त टैग स्थायी रूप से हटा दिए जाएंगे।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld tag inutilizzati verranno rimossi definitivamente."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "未使用のタグ%lld件が完全に削除されます。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld tag tidak digunakan akan dibuang secara kekal."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "แท็กที่ไม่ได้ใช้ %lld รายการจะถูกลบถาวร"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld غیر استعمال شدہ ٹیگ مستقل طور پر ہٹا دیے جائیں گے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld未使用的标签将被永久删除。"
          }
        }
      }
    },

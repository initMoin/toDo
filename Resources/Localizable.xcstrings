    "A toDō changed on more than one device. Review it in Settings.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تغيرت تُدُ على أكثر من جهاز. راجعها في الإعدادات."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un toDō cambio en mas de un dispositivo. Revisalo en Ajustes."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक toDō एक से अधिक डिवाइस पर बदला। उसे सेटिंग्स में देखें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Un toDō e cambiato su piu dispositivi. Controllalo in Impostazioni."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "toDōが複数のデバイスで変更されました。設定で確認してください。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Satu toDō berubah pada lebih daripada satu peranti. Semak dalam Tetapan."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "มี toDō ถูกเปลี่ยนบนมากกว่าหนึ่งอุปกรณ์ ตรวจดูในตั้งค่า"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ایک toDō ایک سے زیادہ ڈیوائسز پر بدلا ہے۔ اسے Settings میں دیکھیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "有一个 toDō 在多台设备上发生变化。请在“设置”中查看。"
          }

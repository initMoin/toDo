    "Location Access Disabled": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم تعطيل الوصول إلى الموقع"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Acceso a la ubicación deshabilitado"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्थान पहुंच अक्षम"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Accesso alla posizione disabilitato"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "位置情報アクセスが無効です"
          }
        },
        "ms": {

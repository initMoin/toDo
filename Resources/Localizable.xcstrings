    "Notifications are off, so toDō cannot alert you when something is due.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الإشعارات متوقفة، لذلك لا يستطيع تُدُ تنبيهك عند حلول موعد شيء."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las notificaciones estan desactivadas, asi que toDō no puede avisarte cuando algo vence."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सूचनाएं बंद हैं, इसलिए कुछ देय होने पर toDō आपको अलर्ट नहीं कर सकता।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le notifiche sono disattivate, quindi toDō non puo avvisarti quando qualcosa scade."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "通知がオフのため、期限が来てもtoDōは通知できません。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pemberitahuan dimatikan, jadi toDō tidak boleh memberi amaran apabila sesuatu perlu dibuat."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ปิดการแจ้งเตือนอยู่ toDō จึงเตือนเมื่อถึงกำหนดไม่ได้"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "Notifications بند ہیں، اس لیے کچھ واجب ہونے پر toDō آپ کو الرٹ نہیں کر سکتا۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通知已关闭，因此到期时 toDō 无法提醒你。"
          }
        }
      }
    },
    "Notifications are off. Open Settings to allow reminder sounds.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الإشعارات متوقفة. افتح الإعدادات للسماح بأصوات التذكير."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las notificaciones estan desactivadas. Abre Ajustes para permitir sonidos."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सूचनाएं बंद हैं। रिमाइंडर ध्वनियों की अनुमति देने के लिए सेटिंग्स खोलें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le notifiche sono disattivate. Apri Impostazioni per consentire i suoni."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "通知がオフです。リマインダー音を許可するには設定を開いてください。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pemberitahuan dimatikan. Buka Tetapan untuk membenarkan bunyi peringatan."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ปิดการแจ้งเตือนอยู่ เปิดตั้งค่าเพื่ออนุญาตเสียงเตือน"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "Notifications بند ہیں۔ یاد دہانی کی آوازوں کی اجازت کے لیے Settings کھولیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通知已关闭。打开“设置”以允许提醒声音。"
          }
        }
      }
    },

    "toDō Sync is selected. Sign in to turn it on; until then, toDō stays with %@.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم تحديد مزامنة تُدُ. سجّل الدخول لتشغيلها؛ إلى ذلك الحين، سيبقى تُدُ مع %@."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō Sync esta seleccionado. Inicia sesion para activarlo; hasta entonces, toDō sigue con %@."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō Sync चुना गया है। इसे चालू करने के लिए साइन इन करें; तब तक toDō %@ के साथ रहेगा।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō Sync e selezionato. Accedi per attivarlo; fino ad allora, toDō resta con %@."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō Syncが選択されています。オンにするにはサインインしてください。それまではtoDōは%@を使います。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō Sync dipilih. Daftar masuk untuk menghidupkannya; sehingga itu, toDō kekal dengan %@."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เลือก toDō Sync แล้ว ลงชื่อเข้าใช้เพื่อเปิดใช้ ก่อนถึงตอนนั้น toDō จะยังใช้ %@"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō Sync منتخب ہے۔ اسے آن کرنے کے لیے سائن ان کریں؛ تب تک toDō %@ کے ساتھ رہے گا۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已选择 toDō Sync。登录即可开启；在此之前，toDō 会继续使用 %@。"
          }
        }
      }
    },

        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "找不到该 toDō。"
          }
        }
      }
    },
    "That toDō may have been deleted or has not synced to this device yet.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ربما تم حذف ذلك تُدُ أو لم تتم مزامنته مع هذا الجهاز بعد."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Es posible que esa tarea pendiente se haya eliminado o aún no se haya sincronizado con este dispositivo."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "वह toDō शायद हटा दिया गया है या अभी तक इस डिवाइस से समन्वयित नहीं हुआ है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Quel toDō potrebbe essere stato eliminato o non ancora sincronizzato su questo dispositivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "そのtoDōは削除されたか、まだこのデバイスに同期されていない可能性があります。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō itu mungkin telah dipadam atau belum disegerakkan ke peranti ini."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō นั้นอาจถูกลบหรือยังไม่ได้ซิงค์มายังอุปกรณ์นี้"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "وہ ٹُڈُو شاید حذف ہو چکا ہے یا ابھی اس ڈیوائس پر سنک نہیں ہوا۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该待办事项可能已被删除或尚未同步到此设备。"
          }
        }
      }
    },
    "The last sync did not finish. %@%@": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم تكتمل آخر مزامنة. %@%@"
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "The last sync did not finish. %1$@%2$@"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La ultima sync no termino. %@%@"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अंतिम सिंक पूरा नहीं हुआ। %@%@"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'ultima sync non e terminata. %@%@"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最後の同期が完了しませんでした。%@%@"
          }
        },
        "ms": {

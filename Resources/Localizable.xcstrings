    "Making sure tags and ToDos stay linked correctly.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "التأكد من بقاء العلامات والمهام مرتبطة بشكل صحيح."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Asegurarse de que las etiquetas y las tareas pendientes permanezcan vinculadas correctamente."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह सुनिश्चित करना कि टैग और ToDos सही ढंग से जुड़े रहें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Assicurati che tag e cose da fare rimangano collegati correttamente."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "タグと ToDo が正しくリンクされた状態に保たれるようにします。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Memastikan teg dan Tugasan kekal dipautkan dengan betul."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ตรวจสอบให้แน่ใจว่าแท็กและสิ่งที่ต้องทำเชื่อมโยงกันอย่างถูกต้อง"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اس بات کو یقینی بنانا کہ ٹیگز اور ٹُڈُوز صحیح طریقے سے جڑے رہیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确保标签和待办事项保持正确链接。"
          }
        }
      }
    },

            "state": "translated",
            "value": "वह श्रेणी चुनें जो इस विजेट को दिखानी चाहिए."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli la categoria da mostrare in questo widget."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このウィジェットに表示するカテゴリを選択します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pilih kategori yang patut dipaparkan oleh widget ini."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เลือกหมวดหมู่ที่วิดเจ็ตนี้ควรแสดง"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "وہ زمرہ منتخب کریں جو یہ ویجٹ دکھائے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择此小部件应显示的类别。"
          }
        }
      }
    },
    "Choose which toDō notifications and app surfaces should be active during a Focus.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر إشعارات تُدُ وواجهات التطبيق التي يجب أن تكون نشطة أثناء نمط التركيز."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elija qué notificaciones de tareas pendientes y superficies de aplicaciones deben estar activas durante unFocus."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चुनें किFocusके दौरान कौन से toDō नोटिफिकेशन और ऐप सरफेस सक्रिय होने चाहिए।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli quali notifiche toDō e superfici dell’app devono essere attive durante un Full immersion."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "集中モード中に有効にするtoDō通知とアプリ表示面を選びます。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pilih pemberitahuan toDō dan permukaan app yang patut aktif semasa Fokus."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เลือกการแจ้งเตือน toDō และพื้นที่แสดงของแอปที่จะเปิดใช้งานระหว่างโฟกัส"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "منتخب کریں کہ فوکس کے دوران کون سی ٹُڈُو اطلاعات اور ایپ سطحیں فعال ہوں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择在Focus期间应激活哪些 toDō 通知和应用程序界面。"
          }
        }
      }
    },

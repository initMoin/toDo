    "Sound test sent. Make sure the device is not muted.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم إرسال اختبار الصوت. تأكد من أن الجهاز ليس مكتومًا."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Prueba de sonido enviada. Asegurate de que el dispositivo no este silenciado."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ध्वनि परीक्षण भेजा गया। सुनिश्चित करें कि डिवाइस म्यूट नहीं है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Test audio inviato. Assicurati che il dispositivo non sia in modalita silenziosa."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サウンドテストを送信しました。デバイスが消音でないことを確認してください。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Ujian bunyi dihantar. Pastikan peranti tidak disenyapkan."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ส่งการทดสอบเสียงแล้ว ตรวจว่าอุปกรณ์ไม่ได้ปิดเสียง"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "آواز کا ٹیسٹ بھیج دیا گیا۔ یقینی بنائیں کہ ڈیوائس خاموش نہیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "声音测试已发送。请确认设备未静音。"
          }
        }
      }
    },

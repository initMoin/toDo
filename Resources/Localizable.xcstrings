    "%@ Due reminders can alert you with quick snooze and mark-done actions. %@. %@": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "%@يمكن أن تنبهك التذكيرات المستحقة من خلال التأجيل السريع والإجراءات المحددة.%@.%@"
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ Due reminders can alert you with quick snooze and mark-done actions. %2$@. %3$@"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@Los recordatorios vencidos pueden alertarlo con una repetición rápida y marcar acciones como realizadas.%@.%@"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@उचित अनुस्मारक आपको त्वरित स्नूज़ और चिह्नित कार्यों के साथ सचेत कर सकते हैं।%@.%@"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ I promemoria di scadenza possono avvisarti con rinvio rapido e azioni per segnare come completato. %@. %@"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@期限リマインダーは、クイック スヌーズや完了マークを付けたアクションでアラートを送信できます。%@。%@"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "%@Peringatan wajar boleh memaklumkan anda dengan tunda pantas dan tindakan tanda selesai.%@.%@"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "%@การแจ้งเตือนครบกำหนดสามารถแจ้งเตือนคุณด้วยการเลื่อนการเตือนอย่างรวดเร็วและการดำเนินการที่ทำเครื่องหมายไว้%@.%@"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ڈیو ریمائنڈرز آپ کو فوری اسنوز اور نشان زد کی گئی کارروائیوں سے آگاہ کر سکتے ہیں۔%@%@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 到期提醒可以通过快速稍后提醒和标记完成操作提醒你。%@。%@"
          }
        }
      }
    },

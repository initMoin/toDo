    "Deleted on another device.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم الحذف على جهاز آخر."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Eliminado en otro dispositivo."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "दूसरे डिवाइस पर हटाया गया."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Eliminato su un altro dispositivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "別のデバイスで削除されました。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Dipadam pada peranti lain."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ลบแล้วบนอุปกรณ์อื่น"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "دوسرے ڈیوائس پر حذف ہو گیا۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已在另一台设备上删除。"
          }
        }
      }
    },
    "Deleted toDōs will be permanently removed after this much time in the trash.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ستتم إزالة تُدُس المحذوفة نهائيًا بعد هذه المدة في سلة المهملات."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las tareas pendientes eliminadas se eliminarán permanentemente después de tanto tiempo en la papelera."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हटाए गए toDōs को कूड़ेदान में इतने समय के बाद स्थायी रूप से हटा दिया जाएगा।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I toDō eliminati verranno rimossi definitivamente dopo questo tempo nel cestino."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "削除したtoDōは、この期間が経過するとゴミ箱から完全に削除されます。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō yang dipadam akan dibuang secara kekal selepas tempoh ini dalam sampah."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō ที่ถูกลบจะถูกลบถาวรหลังจากอยู่ในถังขยะตามระยะเวลานี้"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "حذف شدہ ٹُڈُوز کو ردی کی ٹوکری میں اتنی مدت کے بعد مستقل طور پر ہٹا دیا جائے گا۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已删除的待办事项将在垃圾箱中经过这么长时间后被永久删除。"
          }
        }
      }
    },

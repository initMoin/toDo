    "Active due ToDos appear in Calendar. Completing, archiving, deleting, or removing a due date removes the mirrored event.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تظهر تُدُس النشطة ذات تاريخ الاستحقاق في التقويم. إكمالها أو أرشفتها أو حذفها أو إزالة تاريخ الاستحقاق يحذف الحدث المنعكس."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Activo debido a que las tareas pendientes aparecen en el Calendario. Completar, archivar, eliminar o eliminar una fecha de vencimiento elimina el evento reflejado."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सक्रिय देय कार्य कैलेंडर में दिखाई देते हैं। किसी नियत तिथि को पूरा करना, संग्रहीत करना, हटाना या हटाना प्रतिबिंबित घटना को हटा देता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I ToDo attivi con scadenza appaiono nel Calendario. Completare, archiviare, eliminare o rimuovere una scadenza elimina l’evento riflesso."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "期日付きのアクティブなToDoはカレンダーに表示されます。完了、アーカイブ、削除、期日の削除を行うと、反映されたイベントも削除されます。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo aktif yang mempunyai tarikh akhir muncul dalam Kalendar. Menyelesaikan, mengarkib, memadam atau membuang tarikh akhir akan membuang acara yang dicerminkan."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo ที่ใช้งานอยู่และมีวันครบกำหนดจะแสดงในปฏิทิน การทำเสร็จ เก็บถาวร ลบ หรือลบวันครบกำหนดจะลบกิจกรรมที่สะท้อนไว้"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "فعال مقررہ ٹُڈُوز کیلنڈر میں دکھائی دیتے ہیں۔ انہیں مکمل، آرکائیو، حذف، یا مقررہ تاریخ ہٹانے سے mirrored ایونٹ ہٹ جاتا ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "活动到期待办事项出现在日历中。完成、存档、删除或删除截止日期会删除镜像事件。"
          }
        }
      }
    },

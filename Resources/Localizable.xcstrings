    "Open system Settings to allow notifications for toDō.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "افتح إعدادات النظام للسماح بإشعارات تُدُ."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Abra la Configuración del sistema para permitir notificaciones de tareas pendientes."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō के लिए सूचनाओं की अनुमति देने के लिए सिस्टम सेटिंग्स खोलें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Apri le Impostazioni di sistema per consentire le notifiche per toDō."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "システム設定を開き、toDō の通知を許可します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Buka Tetapan sistem untuk membenarkan pemberitahuan untuk Tugasan."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เปิดการตั้งค่าระบบเพื่ออนุญาตการแจ้งเตือนสำหรับสิ่งที่ต้องทำ"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ٹُڈُو کے لیے اطلاعات کی اجازت دینے کے لیے سسٹم کی ترتیبات کھولیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打开系统设置以允许 toDō 通知。"
          }
        }
      }
    },
    "Open this toDō or use the leading control to mark it done.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "افتح هذا toDō أو استخدم زر البداية لتحديده كمنجز."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Abre este toDō o usa el control inicial para marcarlo como hecho."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस toDō को खोलें या आगे वाले नियंत्रण से इसे पूर्ण चिह्नित करें."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Apri questo toDō o usa il controllo iniziale per segnarlo come fatto."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このtoDōを開くか、先頭の操作で完了にします。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Buka toDō ini atau guna kawalan hadapan untuk menandainya selesai."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เปิด toDō นี้ หรือใช้ปุ่มด้านหน้าเพื่อทำเครื่องหมายว่าเสร็จ"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اس toDō کو کھولیں یا شروع کے کنٹرول سے اسے مکمل نشان زد کریں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打开这个 toDō，或使用前方控件将其标记为完成。"
          }
        }
      }
    },
    "Open toDō": {

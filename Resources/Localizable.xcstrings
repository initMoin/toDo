    "toDō couldn’t save this change. %@": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذر على تُدُ حفظ هذا التغيير. %@"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō no pudo guardar este cambio. %@"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",

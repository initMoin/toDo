    "toDō uses iCloud to keep your Apple devices in step.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يستخدم تُدُ iCloud للحفاظ على توافق أجهزة Apple."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō usa iCloud para mantener tus dispositivos Apple al dia."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō आपके Apple डिवाइस साथ रखने के लिए iCloud इस्तेमाल करता है।"
          }
        },

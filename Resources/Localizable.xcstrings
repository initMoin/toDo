          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "خلفشار کے بغیر آگاہ رہیں"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "保持清醒，不分心"
          }

    "Adds due toDōs to Calendar and removes them when they are finished, archived, deleted, or no longer due.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يضيف تُدُس المستحقة إلى التقويم ويزيلها عند إكمالها أو أرشفتها أو حذفها أو عندما لا تعود مستحقة."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Anade toDōs con fecha a Calendario y los quita cuando se completan, archivan, eliminan o ya no tienen fecha."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "देय toDōs को कैलेंडर में जोड़ता है और पूरा, आर्काइव, डिलीट या बिना देय होने पर हटाता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiunge i toDō in scadenza al Calendario e li rimuove quando sono completati, archiviati, eliminati o non piu in scadenza."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "期限付きtoDōをカレンダーに追加し、完了、アーカイブ、削除、または期限がなくなると削除します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Menambah toDō yang perlu dibuat ke Kalendar dan membuangnya apabila selesai, diarkibkan, dipadam, atau tiada tarikh perlu dibuat."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เพิ่ม toDō ที่ครบกำหนดลงปฏิทิน และนำออกเมื่อเสร็จ เก็บถาวร ลบ หรือไม่มีกำหนดแล้ว"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "واجب toDōs کو کیلنڈر میں شامل کرتا ہے اور مکمل، آرکائیو، حذف یا غیر واجب ہونے پر ہٹا دیتا ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将到期 toDō 添加到日历，并在完成、归档、删除或不再到期时移除。"
          }
        }
      }
    },
    "Adds this choice to %@ snooze.": {
      "localizations": {
        "ar": {

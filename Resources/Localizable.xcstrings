    "%@ completed in the last 7 days.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ أُنجز خلال آخر ٧ أيام."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ completados en los últimos 7 días."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पिछले 7 दिनों में %@ पूर्ण।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ completati negli ultimi 7 giorni."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "過去7日間に %@ 件完了。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ selesai dalam 7 hari lalu."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ รายการเสร็จใน 7 วันที่ผ่านมา"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "گزشتہ ۷ دن میں %@ مکمل۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "过去 7 天完成 %@ 个。"
          }
        }
      }
    },

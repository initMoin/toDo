        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō は、既存の toDō を移動せずにこの同期モードを開始しました。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō memulakan mod penyegerakan ini tanpa mengalihkan toDō sedia ada."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō เริ่มต้นโหมดการซิงค์นี้โดยไม่ต้องย้าย toDō ที่มีอยู่"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ٹُڈُو نے موجودہ ٹُڈُوز کو منتقل کیے بغیر یہ مطابقت پذیری موڈ شروع کیا۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō 在不移动现有 toDō 的情况下启动了此同步模式。"
          }
        }
      }
    },
    "toDō stayed on %@ because %@ could not finish setup.%@": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بقي toDō على %@ لأن %@ لم يتمكن من إكمال الإعداد.%@"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō permaneció en %@ porque %@ no pudo completar la configuración.%@"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō %@ पर रहा क्योंकि %@ सेटअप पूरा नहीं कर सका.%@"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō è rimasto su %@ perché %@ non ha potuto completare la configurazione.%@"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@のままです。%@の設定を完了できませんでした。%@"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō kekal pada %@ kerana %@ tidak dapat menyelesaikan persediaan.%@"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō ยังคงอยู่ที่ %@ เพราะ %@ ตั้งค่าไม่สำเร็จ%@"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō %@ پر رہا کیونکہ %@ سیٹ اپ مکمل نہیں کر سکا۔%@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō 仍停留在 %@，因为 %@ 无法完成设置。%@"

    "Some active toDōs have not moved in over two weeks.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بعض تُدُس النشطة لم تتحرك منذ أكثر من أسبوعين."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Algunos toDōs activos no se han movido en más de dos semanas."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कुछ सक्रिय toDōs दो सप्ताह से अधिक समय से आगे नहीं बढ़े हैं।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Alcuni toDō attivi non si muovono da oltre due settimane."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "一部のアクティブ toDōs は2週間以上動いていません。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Beberapa toDōs aktif tidak bergerak selama lebih dua minggu."

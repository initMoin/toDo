    "Stats": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الإحصاءات"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Estadísticas"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आंकड़े"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Statistiche"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "統計"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Statistik"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "สถิติ"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اعدادوشمار"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "统计"
          }
        }
      }
    },
    "Stats will track completion patterns, workload shape, and long-term momentum. This skeletal version keeps the destination in place while the full metrics model is designed.": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ستتتبع الإحصائيات أنماط الإنجاز وشكل عبء العمل والزخم طويل المدى. تحافظ هذه النسخة الهيكلية على الوجهة في مكانها أثناء تصميم نموذج المقاييس الكاملة."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las estadísticas rastrearán los patrones de finalización, la forma de la carga de trabajo y el impulso a largo plazo. Esta versión esquelética mantiene el destino en su lugar mientras se diseña el modelo de métricas completo."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आँकड़े समापन पैटर्न, कार्यभार आकार और दीर्घकालिक गति को ट्रैक करेंगे। यह कंकाल संस्करण पूर्ण मेट्रिक्स मॉडल डिज़ाइन करते समय गंतव्य को यथावत रखता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le statistiche monitoreranno i modelli di completamento, la forma del carico di lavoro e lo slancio a lungo termine. Questa versione scheletrica mantiene la destinazione in posizione mentre viene progettato il modello di metriche completo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "統計は、完了パターン、ワークロードの形状、長期的な勢いを追跡します。この骨格バージョンは、完全なメトリクス モデルが設計されている間、宛先を所定の位置に保ちます。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Statistik akan menjejaki corak penyiapan, bentuk beban kerja dan momentum jangka panjang. Versi rangka ini mengekalkan destinasi di tempatnya sementara model metrik penuh direka bentuk."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "สถิติจะติดตามรูปแบบความสำเร็จ รูปร่างปริมาณงาน และโมเมนตัมในระยะยาว เวอร์ชันโครงร่างนี้เก็บปลายทางไว้ในขณะที่ออกแบบโมเดลเมตริกเต็มรูปแบบ"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اعدادوشمار تکمیل کے نمونوں، کام کے بوجھ کی شکل، اور طویل مدتی رفتار کو ٹریک کریں گے۔ یہ سکیلیٹل ورژن منزل کو اپنی جگہ پر رکھتا ہے جبکہ میٹرکس کا مکمل ماڈل ڈیزائن کیا گیا ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "统计数据将跟踪完成模式、工作量形状和长期势头。这个骨架版本在设计完整的指标模型时将目的地保持在适当的位置。"
          }
        }
      }
    },
    "Stay aware without distraction": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "البقاء على علم دون تشتيت الانتباه"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantente consciente sin distracciones"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "बिना विचलित हुए जागरूक रहें"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",

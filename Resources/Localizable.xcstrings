        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los elementos se eliminarán permanentemente después de%@."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@के बाद आइटम स्थायी रूप से हटा दिए जाएंगे।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",

    "Permanently deletes all completed and archived toDōs.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحذف نهائيًا كل تُدُس المكتملة والمؤرشفة."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elimina permanentemente todas las tareas pendientes completadas y archivadas."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सभी पूर्ण और संग्रहीत toDōs को स्थायी रूप से हटा देता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Elimina definitivamente tutti i toDō completati e archiviati."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "完了およびアーカイブ済みのtoDōをすべて完全に削除します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Memadam semua toDō selesai dan diarkibkan secara kekal."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ลบ toDō ที่เสร็จแล้วและเก็บถาวรทั้งหมดอย่างถาวร"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "تمام مکمل اور آرکائیو شدہ ٹُڈُوز مستقل طور پر حذف کرتا ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "永久删除所有已完成和存档的待办事项。"
          }
        }
      }
    },

          }
        }
      }
    },
    "Choose where ToDo stores and syncs your ToDos: on this device, in iCloud, or through ToDo Sync.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر أين يخزن تُدُ ويزامن تُدُس الخاصة بك: على هذا الجهاز، في iCloud، أو عبر مزامنة تُدُ."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elija dónde ToDo almacena y sincroniza sus tareas pendientes: en este dispositivo, eniCloudo mediante ToDo Sync."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चुनें कि ToDo आपके ToDos को कहाँ संग्रहीत और सिंक करता है: इस डिवाइस पर,iCloudमें, या ToDo Sync के माध्यम से।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli dove ToDo archivia e sincronizza i tuoi ToDo: su questo dispositivo, in iCloud o tramite ToDo Sync."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDoの保存と同期先を選びます: このデバイス、iCloud、またはToDo Sync。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pilih tempat ToDo menyimpan dan menyegerakkan ToDo anda: pada peranti ini, dalam iCloud, atau melalui ToDo Sync."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เลือกตำแหน่งที่ ToDo จะจัดเก็บและซิงค์ ToDo ของคุณ: บนอุปกรณ์นี้, ใน iCloud หรือผ่าน ToDo Sync"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "منتخب کریں کہ ٹُڈُو آپ کے ٹُڈُوز کہاں محفوظ اور سنک کرے: اس ڈیوائس پر، iCloud میں، یا ٹُڈُو سنک کے ذریعے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择 ToDo 存储和同步您的 ToDo 的位置：在此设备上、iCloud中或通过 ToDo Sync。"
          }
        }
      }
    },

          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Un suono piu netto per promemoria chiari."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "はっきり知らせる鋭いサウンド。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",

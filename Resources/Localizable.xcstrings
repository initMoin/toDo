    "Enable Notifications": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تفعيل الإشعارات"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Activar notificaciones"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सूचनाएँ चालू करें"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Abilita notifiche"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "通知を有効にする"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Dayakan Pemberitahuan"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เปิดการแจ้งเตือน"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اطلاعات فعال کریں"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "启用通知"
          }
        }
      }
    },
    "Enable notifications to receive due reminders, time-sensitive alerts, and quick snooze actions.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قم بتمكين الإشعارات لتلقي التذكيرات المستحقة والتنبيهات الحساسة للوقت وإجراءات الغفوة السريعة."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Habilite las notificaciones para recibir recordatorios vencidos, alertas urgentes y acciones rápidas de repetición de alarma."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "उचित अनुस्मारक, समय-संवेदनशील अलर्ट और त्वरित स्नूज़ क्रियाएं प्राप्त करने के लिए सूचनाएं सक्षम करें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Abilita le notifiche per ricevere promemoria dovuti, avvisi urgenti e azioni di posticipazione rapida."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "通知を有効にして、期日のリマインダー、時間制限のあるアラート、クイック スヌーズ アクションを受け取ります。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Dayakan pemberitahuan untuk menerima peringatan yang sewajarnya, makluman sensitif masa dan tindakan tunda pantas."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เปิดใช้งานการแจ้งเตือนเพื่อรับการแจ้งเตือนที่ครบกำหนด การแจ้งเตือนตามเวลา และการเลื่อนการปลุกอย่างรวดเร็ว"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "مقررہ یاد دہانیوں، وقت کے لحاظ سے حساس انتباہات، اور فوری اسنوز ایکشن حاصل کرنے کے لیے اطلاعات کو فعال کریں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "启用通知以接收到期提醒、时间敏感警报和快速暂停操作。"
          }
        }
      }
    },
    "Enable Tags by Default": {
      "localizations": {
        "ar": {

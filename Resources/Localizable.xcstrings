    "Location Access Disabled": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم تعطيل الوصول إلى الموقع"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Acceso a la ubicación deshabilitado"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्थान पहुंच अक्षम"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Accesso alla posizione disabilitato"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "位置情報アクセスが無効です"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Akses Lokasi Dilumpuhkan"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การเข้าถึงตำแหน่งถูกปิดใช้งาน"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "مقام تک رسائی غیر فعال ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "位置访问已禁用"
          }
        }
      }
    },
    "Location access is off. Enable Always Location access in Settings to use place-based reminders.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الوصول إلى الموقع متوقف. فعّل الوصول الدائم للموقع من الإعدادات لاستخدام التذكيرات حسب المكان."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El acceso a la ubicación está desactivado. Habilite el acceso a la ubicación siempre en Configuración para usar recordatorios basados ​​en lugares."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्थान पहुंच बंद है. स्थान-आधारित अनुस्मारक का उपयोग करने के लिए सेटिंग्स में हमेशा स्थान पहुंच सक्षम करें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'accesso alla posizione è disattivato. Abilita sempre l'accesso alla posizione in Impostazioni per utilizzare promemoria basati sul luogo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "位置情報へのアクセスがオフになっています。場所ベースのリマインダーを使用するには、設定で常に位置情報へのアクセスを有効にします。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Akses lokasi dimatikan. Dayakan akses Sentiasa Lokasi dalam Tetapan untuk menggunakan peringatan berasaskan tempat."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การเข้าถึงตำแหน่งปิดอยู่ เปิดใช้งานการเข้าถึงตำแหน่งเสมอในการตั้งค่าเพื่อใช้การเตือนความจำตามสถานที่"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "مقام تک رسائی بند ہے۔ مقام پر مبنی یاد دہانیوں کے لیے ترتیبات میں ہمیشہ مقام تک رسائی فعال کریں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "位置访问已关闭。在“设置”中启用“始终位置”访问以使用基于地点的提醒。"
          }
        }
      }
    },
    "Location access is unavailable.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الوصول إلى الموقع غير متاح."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El acceso a la ubicación no está disponible."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्थान पहुंच अनुपलब्ध है."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'accesso alla posizione non è disponibile."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "位置情報へのアクセスは利用できません。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",

    "%@ ToDos changed in two places. Review them before ToDo overwrites either version.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم تغيير%@تُدُس في مكانين. قم بمراجعتها قبل أن يقوم تُدُ بالكتابة فوق أي من الإصدارين."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@Las tareas pendientes cambiaron en dos lugares. Revíselos antes de que ToDo sobrescriba cualquiera de las versiones."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@कार्य दो स्थानों पर बदले गए। ToDo द्वारा किसी भी संस्करण को अधिलेखित करने से पहले उनकी समीक्षा करें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@Le cose da fare sono cambiate in due punti. Esaminarli prima che ToDo sovrascriva entrambe le versioni."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ToDo が 2 か所変更されました。 ToDo がいずれかのバージョンを上書きする前に、それらを確認してください。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ToDos berubah di dua tempat. Semak semula sebelum ToDo menimpa mana-mana versi."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ToDos มีการเปลี่ยนแปลงในสองตำแหน่ง ตรวจสอบก่อนที่ ToDo จะเขียนทับเวอร์ชันใดเวอร์ชันหนึ่ง"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ٹُڈُوز دو جگہوں پر تبدیل ہوئے۔ ٹُڈُو کسی بھی ورژن کو اوور رائٹ کرنے سے پہلے ان کا جائزہ لیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ToDos 在两个地方发生了变化。在 ToDo 覆盖任一版本之前查看它们。"
          }
        }
      }
    },

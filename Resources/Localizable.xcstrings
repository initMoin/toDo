            "value": "删除未使用的标签？"
          }
        }
      }
    },
    "Deleted ToDos will be permanently removed after this much time in the trash.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ستتم إزالة تُدُس المحذوفة نهائيًا بعد هذه المدة في سلة المهملات."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las tareas pendientes eliminadas se eliminarán permanentemente después de tanto tiempo en la papelera."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हटाए गए ToDos को कूड़ेदान में इतने समय के बाद स्थायी रूप से हटा दिया जाएगा।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I ToDo eliminati verranno rimossi definitivamente dopo questo tempo nel cestino."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "削除したToDoは、この期間が経過するとゴミ箱から完全に削除されます。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo yang dipadam akan dibuang secara kekal selepas tempoh ini dalam sampah."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo ที่ถูกลบจะถูกลบถาวรหลังจากอยู่ในถังขยะตามระยะเวลานี้"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "حذف شدہ ٹُڈُوز کو ردی کی ٹوکری میں اتنی مدت کے بعد مستقل طور پر ہٹا دیا جائے گا۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已删除的待办事项将在垃圾箱中经过这么长时间后被永久删除。"
          }
        }
      }
    },
    "Deletes current tags and clears existing tag links.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحذف الوسوم الحالية ويمسح روابط الوسوم الموجودة."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elimina las etiquetas actuales y borra los enlaces de etiquetas existentes."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "वर्तमान टैग हटाता है और मौजूदा टैग लिंक साफ़ करता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Elimina i tag attuali e cancella i collegamenti tag esistenti."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在のタグを削除し、既存のタグリンクをクリアします。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Memadam tag semasa dan mengosongkan pautan tag sedia ada."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ลบแท็กปัจจุบันและล้างลิงก์แท็กที่มีอยู่"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "موجودہ ٹیگز حذف کرتا ہے اور موجودہ ٹیگ روابط صاف کرتا ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "删除当前标签并清除现有标签链接。"
          }
        }
      }
    },

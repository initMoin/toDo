    "ToDo now keeps what matters on this device.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحتفظ تُدُ الآن بما يهم على هذا الجهاز."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo ahora guarda lo importante en este dispositivo."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo अब इस डिवाइस पर जो मायने रखता है उसे रखता है।"
          }
        },
        "it": {
          "stringUnit": {

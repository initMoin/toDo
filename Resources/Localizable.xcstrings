    "Sync needs review: %lld ToDos changed in two places.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "المزامنة تحتاج إلى مراجعة: تغيّرت %lld من تُدُس في مكانين."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La sincronización necesita revisión:%lldLas tareas pendientes cambiaron en dos lugares."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सिंक की समीक्षा की आवश्यकता है:%lldकार्य दो स्थानों पर बदले गए।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sincronizzazione da rivedere: %lld ToDo sono cambiati in due punti."

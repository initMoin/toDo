    "No extra detail yet. Add a due date, notes, tags, or NanoDos to make this panel useful.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا توجد تفاصيل إضافية بعد. أضف تاريخ استحقاق أو ملاحظات أو وسومًا أو نَنُدُس لجعل هذه اللوحة مفيدة."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no hay detalles adicionales. Agregue una fecha de vencimiento, notas, etiquetas o NanoDos para que este panel sea útil."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अभी तक कोई अतिरिक्त विवरण नहीं. इस पैनल को उपयोगी बनाने के लिए एक नियत तिथि, नोट्स, टैग या नैनोडोस जोड़ें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ancora nessun dettaglio. Aggiungi scadenza, note, tag o NanoDo per rendere utile questo pannello."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "追加の詳細はまだありません。期日、メモ、タグ、NanoDoを追加するとこのパネルが役立ちます。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Belum ada butiran tambahan. Tambah tarikh akhir, nota, tag atau NanoDo untuk menjadikan panel ini berguna."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ยังไม่มีรายละเอียดเพิ่มเติม เพิ่มวันครบกำหนด บันทึก แท็ก หรือ NanoDo เพื่อให้แผงนี้มีประโยชน์"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ابھی کوئی اضافی تفصیل نہیں۔ اس پینل کو مفید بنانے کے لیے مقررہ تاریخ، نوٹس، ٹیگز، یا نَینوڈوز شامل کریں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "目前还没有额外的细节。添加截止日期、注释、标签或 NanoDos 以使此面板有用。"
          }
        }
      }
    },

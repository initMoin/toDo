    "Copy your iCloud-backed ToDos into ToDo Sync for Android and web access.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "انسخ المهام المدعومة منiCloudإلى تُدُ Sync لـAndroidوالوصول إلى الويب."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Copie sus tareas pendientes respaldadas poriClouden ToDo Sync paraAndroidy acceso web."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Androidऔर वेब एक्सेस के लिए अपनेiCloud-समर्थित ToDos को ToDo Sync में कॉपी करें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Copia i tuoi ToDos supportati da ZXPLACEholder0ZX in ToDo Sync per ZXPLACEholder1ZX e l'accesso al web."

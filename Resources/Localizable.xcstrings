        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اپنےiCloudکی حمایت یافتہ ٹُڈُوز کوAndroidاور ویب رسائی کے لیے ٹُڈُو Sync میں کاپی کریں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将iCloud支持的 ToDo 复制到 ToDo Sync 中，以进行Android和 Web 访问。"
          }
        }
      }
    },
    "Copy your latest synced ToDos into device-only storage and step away from account sync.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "انسخ أحدث المهام التي تمت مزامنتها إلى وحدة تخزين الجهاز فقط وابتعد عن مزامنة الحساب."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Copie sus últimas tareas pendientes sincronizadas en el almacenamiento exclusivo del dispositivo y aléjese de la sincronización de cuentas."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपने नवीनतम सिंक किए गए ToDos को केवल-डिवाइस स्टोरेज में कॉपी करें और अकाउंट सिंक से दूर हो जाएं।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Copia le tue ultime attività sincronizzate nello spazio di archiviazione riservato al dispositivo ed evita la sincronizzazione dell'account."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最新の同期 ToDo をデバイス専用ストレージにコピーし、アカウント同期から離れます。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Salin ToDo yang disegerakkan terbaharu anda ke dalam storan peranti sahaja dan jauhi daripada penyegerakan akaun."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "คัดลอก ToDos ที่ซิงค์ล่าสุดของคุณลงในที่เก็บข้อมูลเฉพาะอุปกรณ์และก้าวออกจากการซิงค์บัญชี"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اپنے تازہ ترین مطابقت پذیر ٹُڈُوز کو صرف ڈیوائس اسٹوریج میں کاپی کریں اور اکاؤنٹ کی مطابقت پذیری سے دور رہیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将最新同步的待办事项复制到仅限设备的存储中，并远离帐户同步。"
          }
        }
      }
    },

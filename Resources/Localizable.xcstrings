    "Today has scheduled work ready for focused attention.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اليوم لديه عمل مجدول جاهز لتركيزك."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hoy hay trabajo programado listo para atención enfocada."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आज निर्धारित कार्य केंद्रित ध्यान के लिए तैयार है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Oggi c’è lavoro programmato pronto per attenzione mirata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今日は集中して取り組む予定作業があります。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Hari ini ada kerja berjadual yang sedia diberi tumpuan."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "วันนี้มีงานที่กำหนดเวลาไว้พร้อมให้โฟกัส"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "آج شیڈول شدہ کام مرکوز توجہ کے لیے تیار ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "今天有计划任务需要专注处理。"
          }
        }
      }
    },

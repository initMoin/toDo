        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "یہ انتخاب %@ اسنوز میں شامل کرتا ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将此选项添加到 %@ 稍后提醒。"
          }
        }
      }
    },
    "Adopt local toDōs into toDō Sync for cross-platform access.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اعتماد تُدُس المحلية في تُدُ Sync للوصول عبر الأنظمة الأساسية."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Adopte tareas pendientes locales en toDō Sync para obtener acceso multiplataforma."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "क्रॉस-प्लेटफ़ॉर्म पहुंच के लिए स्थानीय toDōs को toDō Sync में अपनाएं।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Adotta le attività toDō locali in toDō Sync per l'accesso multipiattaforma."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ローカル toDō を toDō Sync に採用して、クロスプラットフォーム アクセスを実現します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Gunakan toDōs tempatan ke dalam toDō Sync untuk akses merentas platform."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "นำ toDōs ภายในมาใช้ใน toDō Sync เพื่อการเข้าถึงข้ามแพลตฟอร์ม"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "کراس پلیٹ فارم تک رسائی کے لیے مقامی ٹُڈُوز کو ٹُڈُو Sync میں اپنائیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将本地 toDō 纳入 toDō Sync 中以实现跨平台访问。"
          }
        }
      }
    },

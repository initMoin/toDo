    "%@ is saved. Close and reopen ToDo when you are ready to activate it.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم حفظ%@. أغلق وأعد فتح تُدُ عندما تكون جاهزًا لتنشيطه."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se guarda%@. Cierra y vuelve a abrir ToDo cuando estés listo para activarlo."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@सहेजा गया है. जब आप ToDo को सक्रिय करने के लिए तैयार हों तो उसे बंद करें और पुनः खोलें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@viene salvato. Chiudi e riapri ToDo quando sei pronto per attivarlo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@が保存されます。 ToDo を閉じて、アクティブ化する準備ができたら再度開きます。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "%@disimpan. Tutup dan buka semula ToDo apabila anda bersedia untuk mengaktifkannya."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "บันทึก%@แล้ว ปิดและเปิด ToDo อีกครั้งเมื่อคุณพร้อมที่จะเปิดใช้งาน"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "%@محفوظ ہو گیا ہے۔ ٹُڈُو کو بند کریں اور دوبارہ کھولیں جب آپ اسے فعال کرنے کے لیے تیار ہوں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@已保存。当您准备好激活待办事项时，关闭并重新打开它。"
          }
        }
      }
    },
    "%@ is selected, but no account is signed in yet. ToDos stay on this device until you authenticate.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم تحديد%@، ولكن لم يتم تسجيل الدخول إلى أي حساب حتى الآن. تبقى المهام على هذا الجهاز حتى تقوم بالمصادقة."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se selecciona%@, pero aún no se ha iniciado sesión en ninguna cuenta. Las tareas pendientes permanecen en este dispositivo hasta que usted se autentique."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@चयनित है, लेकिन अभी तक किसी खाते से साइन इन नहीं किया गया है। जब तक आप प्रमाणित नहीं करते तब तक ToDos इस डिवाइस पर बने रहेंगे।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@è selezionato, ma non è stato ancora effettuato l'accesso a nessun account. Le attività da svolgere rimangono su questo dispositivo finché non esegui l'autenticazione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@が選択されていますが、アカウントはまだサインインしていません。 ToDo は認証されるまでこのデバイス上に残ります。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "%@dipilih, tetapi tiada akaun dilog masuk lagi. ToDos kekal pada peranti ini sehingga anda mengesahkan."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เลือก%@แล้ว แต่ยังไม่มีบัญชีที่ลงชื่อเข้าใช้ สิ่งที่ต้องทำจะคงอยู่ในอุปกรณ์นี้จนกว่าคุณจะตรวจสอบสิทธิ์"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "%@منتخب ہے، لیکن ابھی تک کوئی اکاؤنٹ سائن ان نہیں ہے۔ ٹُڈُوز اس ڈیوائس پر اس وقت تک رہتے ہیں جب تک آپ تصدیق نہیں کر لیتے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择了%@，但尚未登录任何帐户。在您进行身份验证之前，待办事项将保留在此设备上。"
          }
        }
      }
    },
    "%@ is selected. Open Settings to sign in; until then, ToDo stays on %@.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم تحديد%@. افتح الإعدادات لتسجيل الدخول؛ وحتى ذلك الحين، يظل تُدُ على%@."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ is selected. Open Settings to sign in; until then, ToDo stays on %2$@."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se selecciona%@. Abra Configuración para iniciar sesión; Hasta entonces, ToDo permanece en%@."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@चयनित है. साइन इन करने के लिए सेटिंग्स खोलें; तब तक, ToDo%@पर बना रहता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@è selezionato. Apri Impostazioni per accedere; fino ad allora, ToDo rimane su%@."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@が選択されています。設定を開いてサインインします。それまで、ToDo は%@に残ります。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "%@dipilih. Buka Tetapan untuk log masuk; sehingga itu, ToDo kekal pada%@."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เลือก%@แล้ว เปิดการตั้งค่าเพื่อลงชื่อเข้าใช้ ถึงเวลานั้น ToDo จะยังคงอยู่ใน%@"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "%@کو منتخب کیا گیا ہے۔ سائن ان کرنے کے لیے ترتیبات کھولیں؛ تب تک، ٹُڈُو%@پر رہتا ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择%@。打开“设置”进行登录；在此之前，ToDo 停留在%@上。"
          }
        }
      }
    },
    "%@ is selected. Sign in to finish turning it on.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم تحديد%@. قم بتسجيل الدخول لإنهاء تشغيله."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se selecciona%@. Inicia sesión para terminar de encenderlo."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@चयनित है. इसे चालू करना समाप्त करने के लिए साइन इन करें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@è selezionato. Accedi per completare l'attivazione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@が選択されています。サインインして有効化を完了します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "%@dipilih. Log masuk untuk menyelesaikan menghidupkannya."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เลือก%@แล้ว ลงชื่อเข้าใช้เพื่อเปิดใช้งานให้เสร็จสิ้น"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "%@کو منتخب کیا گیا ہے۔ اسے آن کرنا مکمل کرنے کے لیے سائن ان کریں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择%@。登录以完成开启。"
          }
        }
      }
    },
    "%@ is selected. ToDo is still using %@ until setup completes.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم تحديد%@. لا يزال تُدُ يستخدم%@حتى يكتمل الإعداد."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ is selected. ToDo is still using %2$@ until setup completes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se selecciona%@. ToDo seguirá usando%@hasta que se complete la instalación."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@चयनित है. सेटअप पूरा होने तक ToDo अभी भी%@का उपयोग कर रहा है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@è selezionato. ToDo utilizza ancora%@fino al completamento della configurazione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@が選択されています。 ToDo はセットアップが完了するまで%@を使用します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "%@dipilih. ToDo masih menggunakan%@sehingga persediaan selesai."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เลือก%@แล้ว ToDo ยังคงใช้%@จนกว่าการตั้งค่าจะเสร็จสิ้น"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "%@کو منتخب کیا گیا ہے۔ ٹُڈُو سیٹ اپ مکمل ہونے تک%@استعمال کر رہا ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择%@。在设置完成之前，ToDo 仍使用%@。"
          }
        }

    "New ToDos start with tag entry available instead of staying focused only on the task text.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تبدأ تُدُس الجديدة مع إتاحة إدخال الوسوم بدل التركيز فقط على نص المهمة."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las nuevas tareas pendientes comienzan con la entrada de etiquetas disponible en lugar de centrarse únicamente en el texto de la tarea."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "नए ToDos केवल कार्य टेक्स्ट पर केंद्रित रहने के बजाय उपलब्ध टैग प्रविष्टि के साथ प्रारंभ होते हैं।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I nuovi ToDo iniziano con l’inserimento dei tag disponibile invece di concentrarsi solo sul testo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "新しいToDoでは、タスク本文だけでなくタグ入力も最初から使えます。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo baharu bermula dengan medan tag tersedia, bukan hanya fokus pada teks tugas."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo ใหม่จะเริ่มโดยมีช่องแท็กพร้อมใช้งาน แทนที่จะเน้นเฉพาะข้อความงาน"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "نئے ٹُڈُوز صرف ٹاسک متن پر مرکوز رہنے کے بجائے ٹیگ اندراج کے ساتھ شروع ہوتے ہیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "新的待办事项从可用的标签条目开始，而不是仅关注任务文本。"
          }
        }
      }
    },

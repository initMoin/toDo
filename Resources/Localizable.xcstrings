          "stringUnit": {
            "state": "translated",
            "value": "أبقِ toDō في الوضع الفاتح."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén toDō en modo claro."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō को हल्के मोड में रखें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantieni toDō in modalità chiara."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "toDōをライトモードのままにします。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Kekalkan toDō dalam mod cerah."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ใช้ toDō ในโหมดสว่างเสมอ"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō کو روشن موڈ میں رکھیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "让 toDō 保持浅色模式。"
          }
        }
      }
    },
    "Keep what matters available across iPhone, Android, and web.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اجعل ما يهم متاحًا على iPhone وAndroid والويب."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén lo importante disponible en iPhone, Android y web."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जो मायने रखता है उसे iPhone, Android और वेब पर उपलब्ध रखें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tieni cio che conta disponibile su iPhone, Android e web."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "大切なものをiPhone、Android、Webで使えるようにします。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pastikan perkara penting tersedia pada iPhone, Android dan web."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เก็บสิ่งสำคัญให้ใช้ได้บน iPhone, Android และเว็บ"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اہم چیزیں iPhone، Android اور web پر دستیاب رکھیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "让重要内容在 iPhone、Android 和网页上都可用。"
          }
        }
      }
    },
    "Keep your Apple devices in step with iCloud.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حافظ على توافق أجهزة Apple عبر iCloud."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén tus dispositivos Apple al dia con iCloud."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud के साथ अपने Apple डिवाइस साथ रखें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantieni i tuoi dispositivi Apple allineati con iCloud."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloudでAppleデバイスの足並みをそろえます。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Selaraskan peranti Apple anda dengan iCloud."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ทำให้อุปกรณ์ Apple ของคุณตรงกันด้วย iCloud"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اپنی Apple ڈیوائسز کو iCloud کے ساتھ ہم آہنگ رکھیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用 iCloud 让 Apple 设备保持同步。"
          }
        }
      }
    },
    "Keep your toDōs only on this device.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "احتفظ بتُدُس على هذا الجهاز فقط."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén tus toDōs solo en este dispositivo."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपने toDōs केवल इस डिवाइस पर रखें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tieni i tuoi toDō solo su questo dispositivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "toDōをこのデバイスだけに保存します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Simpan toDō anda hanya pada peranti ini."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เก็บ toDō ไว้บนอุปกรณ์นี้เท่านั้น"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اپنے toDōs صرف اس ڈیوائس پر رکھیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅将 toDō 保存在此设备上。"
          }
        }
      }
    },

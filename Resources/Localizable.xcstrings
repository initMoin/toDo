    "Warm, loud, and built for urgency.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "دافئ وجريء ومصمم للإلحاح."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cálido, llamativo y hecho para la urgencia."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "गरम, दमदार, और तात्कालिकता के लिए बनाया गया।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Caldo, deciso e pensato per l’urgenza."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "温かく大胆で、緊急感のために設計。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Hangat, lantang, dan dibina untuk keutamaan segera."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "อบอุ่น เด่นชัด และออกแบบมาเพื่อความเร่งด่วน"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "گرم، نمایاں، اور فوری کاموں کے لیے بنایا گیا۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "温暖、醒目，为紧迫事项而设。"
          }
        }
      }
    },

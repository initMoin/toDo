    "iOS will ask for location access. Choose Always for reliable arrival and leaving reminders.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيطلب iOS الوصول إلى الموقع. اختر دائمًا لتذكيرات وصول ومغادرة موثوقة."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS solicitará acceso a la ubicación. Elija Siempre para obtener recordatorios confiables de llegada y salida."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS लोकेशन एक्सेस मांगेगा. विश्वसनीय आगमन और प्रस्थान अनुस्मारक के लिए हमेशा चुनें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS chiederà l'accesso alla posizione. Scegli Sempre per promemoria affidabili di arrivo e partenza."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS は位置情報へのアクセスを要求します。確実な到着と出発のリマインダーを得るには、「常に」を選択します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS akan meminta akses lokasi. Pilih Sentiasa untuk peringatan ketibaan dan meninggalkan yang boleh dipercayai."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS จะขอการเข้าถึงตำแหน่ง เลือกเสมอสำหรับการเตือนการมาถึงและออกจากที่เชื่อถือได้"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS مقام تک رسائی مانگے گا۔ قابل اعتماد آمد اور روانگی کی یاد دہانیوں کے لیے ہمیشہ منتخب کریں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS 将要求位置访问。选择始终以获得可靠的到达和离开提醒。"
          }
        }
      }
    },
    "Items will be permanently deleted after %@.": {
      "localizations": {
        "ar": {
          "stringUnit": {

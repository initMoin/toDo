    "Details, notes, tags, reminders, and NanoDos appear here when a toDō has more to show.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تظهر التفاصيل والملاحظات والوسوم والتذكيرات ونَنُدُس هنا عندما يحتوي تُدُ على المزيد لعرضه."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los detalles, notas, etiquetas, recordatorios y NanoDos aparecen aquí cuando una tarea pendiente tiene más que mostrar."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "विवरण, नोट्स, टैग, रिमाइंडर और नैनोडोस यहां तब दिखाई देते हैं जब टूडू के पास दिखाने के लिए और भी बहुत कुछ होता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Dettagli, note, tag, promemoria e NanoDo appaiono qui quando un toDō ha altro da mostrare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "詳細、メモ、タグ、リマインダー、NanoDoは、toDōに追加情報があるとここに表示されます。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Butiran, nota, tag, peringatan dan NanoDo muncul di sini apabila toDō mempunyai maklumat tambahan."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "รายละเอียด บันทึก แท็ก การเตือน และ NanoDo จะแสดงที่นี่เมื่อ toDō มีข้อมูลเพิ่มเติม"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "جب کسی ٹُڈُو میں مزید دکھانے کو ہو تو تفصیلات، نوٹس، ٹیگز، یاد دہانیاں، اور نَینوڈوز یہاں ظاہر ہوتے ہیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当待办事项有更多内容要显示时，详细信息、注释、标签、提醒和 NanoDos 会显示在此处。"
          }
        }
      }
    },

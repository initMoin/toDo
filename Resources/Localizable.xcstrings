    "If you already used %@ on another device, choose the existing-destination option first.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إذا كنت قد استخدمت %@ على جهاز آخر، فاختر خيار الوجهة الموجودة أولًا."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si ya usaste %@ en otro dispositivo, elige primero la opción de destino existente."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अगर आपने किसी दूसरे डिवाइस पर %@ पहले से उपयोग किया है, तो पहले मौजूदा गंतव्य वाला विकल्प चुनें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Se hai già usato %@ su un altro dispositivo, scegli prima l’opzione della destinazione esistente."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "別のデバイスで %@ をすでに使っている場合は、先に既存の保存先を使うオプションを選んでください。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Jika anda sudah menggunakan %@ pada peranti lain, pilih pilihan destinasi sedia ada dahulu."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "หากคุณเคยใช้ %@ บนอุปกรณ์อื่นแล้ว ให้เลือกตัวเลือกปลายทางที่มีอยู่ก่อน"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اگر آپ نے کسی دوسری ڈیوائس پر %@ پہلے ہی استعمال کیا ہے، تو پہلے موجودہ منزل والا اختیار منتخب کریں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如果你已在另一台设备上使用过 %@，请先选择使用现有目标数据的选项。"
          }
        }
      }
    },

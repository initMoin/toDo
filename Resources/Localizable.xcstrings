        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "上次同步未完成。%@%@"
          }
        }
      }
    },
    "The last sync did not finish. Tap refresh to try again.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم تكتمل آخر مزامنة. اضغط تحديث للمحاولة مرة أخرى."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La ultima sync no termino. Toca actualizar para intentar de nuevo."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अंतिम सिंक पूरा नहीं हुआ। फिर कोशिश करने के लिए रीफ्रेश टैप करें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'ultima sync non e terminata. Tocca aggiorna per riprovare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最後の同期が完了しませんでした。更新をタップして再試行してください。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Sync terakhir tidak selesai. Ketik segar semula untuk cuba lagi."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การซิงก์ล่าสุดไม่เสร็จ แตะรีเฟรชเพื่อลองอีกครั้ง"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "آخری sync مکمل نہیں ہوئی۔ دوبارہ کوشش کے لیے refresh پر ٹیپ کریں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "上次同步未完成。轻点刷新重试。"
          }
        }
      }
    },
    "The original toDō yellow and blue.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الأصفر والأزرق الأصليان لـ toDō."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El amarillo y azul originales de toDō."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō का मूल पीला और नीला।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il giallo e blu originali di toDō."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō オリジナルの黄色と青。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Kuning dan biru asal toDō."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "สีเหลืองและสีน้ำเงินดั้งเดิมของ toDō"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō کا اصل پیلا اور نیلا۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō 原本的黄色与蓝色。"
          }
        }
      }
    },
    "This cannot be undone.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يمكن التراجع عن هذا."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto no se puede deshacer."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इसे असंपादित नहीं किया जा सकता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa azione non può essere annullata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この操作は取り消せません。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tindakan ini tidak boleh dibuat asal."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การดำเนินการนี้ไม่สามารถย้อนกลับได้"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "یہ واپس نہیں ہو سکتا۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此操作无法撤消。"
          }
        }
      }
    },
    "This device currently shows %@. Choose carefully: copying these toDōs into %@ can create duplicates if the same toDōs already exist there from another device.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يعرض هذا الجهاز حاليًا %@. اختر بعناية: قد يؤدي نسخ هذه toDōs إلى %@ إلى إنشاء نُسخ مكررة إذا كانت نفس toDōs موجودة هناك بالفعل من جهاز آخر."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este dispositivo muestra actualmente %@. Elige con cuidado: copiar estos toDōs a %@ puede crear duplicados si los mismos toDōs ya existen allí desde otro dispositivo."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह डिवाइस अभी %@ दिखा रहा है। सावधानी से चुनें: इन toDōs को %@ में कॉपी करने से डुप्लिकेट बन सकते हैं अगर वही toDōs किसी दूसरे डिवाइस से पहले से मौजूद हैं।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo dispositivo mostra attualmente %@. Scegli con attenzione: copiare questi toDō in %@ può creare duplicati se gli stessi toDō esistono già lì da un altro dispositivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このデバイスには現在 %@ が表示されています。慎重に選んでください。同じ toDō が別のデバイスからすでに %@ にある場合、これらの toDō をコピーすると重複が作成されることがあります。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Peranti ini sedang menunjukkan %@. Pilih dengan teliti: menyalin toDōs ini ke %@ boleh mencipta pendua jika toDōs yang sama sudah wujud di sana daripada peranti lain."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "อุปกรณ์นี้กำลังแสดง %@ อยู่ โปรดเลือกอย่างระมัดระวัง: การคัดลอก toDōs เหล่านี้ไปยัง %@ อาจสร้างรายการซ้ำ หาก toDōs เดียวกันมีอยู่จากอุปกรณ์อื่นแล้ว"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "یہ ڈیوائس اس وقت %@ دکھا رہی ہے۔ احتیاط سے انتخاب کریں: ان toDōs کو %@ میں کاپی کرنے سے نقلیں بن سکتی ہیں اگر وہی toDōs کسی دوسری ڈیوائس سے وہاں پہلے سے موجود ہوں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此设备当前显示 %@。请谨慎选择：如果相同的 toDōs 已经从另一台设备存在于 %@ 中，复制这些 toDōs 可能会产生重复项。"
          }
        }
      }
    },
    "This device currently shows %@. iCloud and toDō Sync are separate places, so they may already have toDōs from another device.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يعرض هذا الجهاز حاليًا %@. iCloud ومزامنة تُدُ مكانان منفصلان، لذلك قد يكون لديهما تُدُس من جهاز آخر."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este dispositivo muestra %@. iCloud y toDō Sync son lugares separados, asi que puede que ya tengan toDōs de otro dispositivo."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह डिवाइस अभी %@ दिखा रहा है। iCloud और toDō Sync अलग जगहें हैं, इसलिए उनमें दूसरे डिवाइस के toDōs हो सकते हैं।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo dispositivo mostra %@. iCloud e toDō Sync sono luoghi separati, quindi potrebbero gia avere toDō da un altro dispositivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このデバイスには現在%@が表示されています。iCloudとtoDō Syncは別の場所なので、別のデバイスのtoDōがすでにある場合があります。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Peranti ini sedang menunjukkan %@. iCloud dan toDō Sync ialah tempat berasingan, jadi mungkin sudah ada toDō dari peranti lain."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "อุปกรณ์นี้แสดง %@ อยู่ตอนนี้ iCloud และ toDō Sync เป็นคนละที่ จึงอาจมี toDō จากอุปกรณ์อื่นอยู่แล้ว"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "یہ ڈیوائس فی الحال %@ دکھا رہی ہے۔ iCloud اور toDō Sync الگ جگہیں ہیں، اس لیے ان میں دوسری ڈیوائس کے toDōs پہلے سے ہو سکتے ہیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此设备当前显示 %@。iCloud 和 toDō Sync 是不同位置，所以其中可能已有其他设备的 toDō。"
          }
        }
      }
    },
    "This device is not ready for remote reminders yet.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هذا الجهاز ليس جاهزًا للتذكيرات البعيدة بعد."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este dispositivo aun no esta listo para recordatorios remotos."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह डिवाइस अभी रिमोट रिमाइंडर के लिए तैयार नहीं है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo dispositivo non e ancora pronto per i promemoria remoti."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このデバイスはまだリモートリマインダーの準備ができていません。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Peranti ini belum sedia untuk peringatan jauh."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "อุปกรณ์นี้ยังไม่พร้อมสำหรับการเตือนระยะไกล"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "یہ ڈیوائس ابھی remote reminders کے لیے تیار نہیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此设备尚未准备好远程提醒。"
          }
        }
      }
    },
    "This Device Only": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هذا الجهاز فقط"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo este dispositivo"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "केवल यह डिवाइस"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo questo dispositivo"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このデバイスのみ"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Peranti Ini Sahaja"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "อุปกรณ์นี้เท่านั้น"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "صرف یہ آلہ"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅此设备"
          }
        }
      }
    },
    "This permanently deletes all items in the trash. This cannot be undone.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحذف هذا كل العناصر في سلة المهملات نهائيًا. لا يمكن التراجع عن هذا."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto elimina permanentemente todos los elementos de la papelera. Esto no se puede deshacer."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह ट्रैश में मौजूद सभी आइटम को स्थायी रूप से हटा देता है। इसे असंपादित नहीं किया जा सकता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Elimina definitivamente tutti gli elementi nel cestino. Questa azione non può essere annullata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ゴミ箱内のすべての項目を完全に削除します。この操作は取り消せません。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Ini memadam semua item dalam sampah secara kekal. Tindakan ini tidak boleh dibuat asal."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การดำเนินการนี้จะลบรายการทั้งหมดในถังขยะอย่างถาวรและไม่สามารถย้อนกลับได้"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "یہ ردی کے تمام آئٹمز مستقل طور پر حذف کرتا ہے۔ یہ واپس نہیں ہو سکتا۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这将永久删除垃圾箱中的所有项目。此操作无法撤消。"
          }
        }
      }
    },
    "This permanently deletes every completed and archived toDō.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحذف هذا كل تُدُ مكتمل ومؤرشف نهائيًا."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto elimina permanentemente todas las tareas pendientes completadas y archivadas."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह प्रत्येक पूर्ण और संग्रहीत toDō को स्थायी रूप से हटा देता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Elimina definitivamente ogni toDō completato e archiviato."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "完了およびアーカイブ済みのtoDōをすべて完全に削除します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Ini memadam setiap toDō selesai dan diarkibkan secara kekal."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ลบ toDō ที่เสร็จแล้วและเก็บถาวรทั้งหมดอย่างถาวร"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "یہ ہر مکمل اور آرکائیو شدہ ٹُڈُو مستقل طور پر حذف کرتا ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这将永久删除每个已完成并存档的待办事项。"
          }
        }
      }
    },
    "This reminder uses your selected notification sound.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يستخدم هذا التذكير صوت الإشعار الذي اخترته."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este recordatorio usa el sonido de notificación seleccionado."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह रिमाइंडर आपकी चुनी हुई सूचना ध्वनि का उपयोग करता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo promemoria usa il suono di notifica selezionato."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このリマインダーは選択した通知音を使用します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Peringatan ini menggunakan bunyi pemberitahuan yang anda pilih."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การเตือนนี้ใช้เสียงแจ้งเตือนที่คุณเลือก"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "یہ یاددہانی آپ کی منتخب کردہ اطلاع کی آواز استعمال کرتی ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此提醒会使用你选择的通知声音。"
          }
        }
      }
    },
    "This removes all existing tags and clears tag links on toDōs and nanoDos.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يزيل هذا كل الوسوم الموجودة ويمسح روابط الوسوم على تُدُس ونَنُدُس."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto elimina todas las etiquetas existentes y borra los enlaces de etiquetas en toDōs y nanoDos."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह सभी मौजूदा टैग हटा देता है और toDōs और nanoDos पर टैग लिंक साफ़ कर देता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rimuove tutti i tag esistenti e cancella i collegamenti tag su toDō e nanoDo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "既存のタグをすべて削除し、toDōとnanoDoのタグリンクをクリアします。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Ini membuang semua tag sedia ada dan mengosongkan pautan tag pada toDō dan nanoDo."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ลบแท็กที่มีอยู่ทั้งหมดและล้างลิงก์แท็กบน toDō และ nanoDo"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "یہ تمام موجودہ ٹیگز ہٹاتا ہے اور ٹُڈُوز اور نَینوڈوز پر ٹیگ روابط صاف کرتا ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这将删除所有现有标签并清除 toDōs 和 nanoDos 上的标签链接。"
          }
        }
      }
    },
    "This removes the selected toDō.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يزيل هذا تُدُ المحدد."
          }
        },

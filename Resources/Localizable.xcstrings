    "Updating this device with synced toDōs.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تحديث هذا الجهاز مع المهام المتزامنة."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Actualizando este dispositivo con tareas pendientes sincronizadas."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस डिवाइस को सिंक किए गए toDōs के साथ अपडेट किया जा रहा है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiornamento di questo dispositivo con le attività da fare sincronizzate."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "同期された toDō でこのデバイスを更新しています。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Mengemas kini peranti ini dengan toDōs yang disegerakkan."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "กำลังอัปเดตอุปกรณ์นี้ด้วย toDōs ที่ซิงค์ไว้"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "مطابقت پذیر ٹُڈُوز کے ساتھ اس آلہ کو اپ ڈیٹ کیا جا رہا ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用同步的待办事项更新此设备。"
          }
        }
      }
    },

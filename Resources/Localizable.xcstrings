    },
    "1 toDō changed on more than one device. Choose which version to keep.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تغيرت تُدُ واحدة على أكثر من جهاز. اختر النسخة التي تريد الاحتفاظ بها."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "1 toDō cambio en mas de un dispositivo. Elige que version conservar."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "1 toDō एक से अधिक डिवाइस पर बदला। चुनें कि कौन सा संस्करण रखना है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "1 toDō e cambiato su piu dispositivi. Scegli quale versione tenere."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "1件のtoDōが複数のデバイスで変更されました。残すバージョンを選んでください。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "1 toDō berubah pada lebih daripada satu peranti. Pilih versi yang mahu disimpan."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō 1 รายการถูกเปลี่ยนบนมากกว่าหนึ่งอุปกรณ์ เลือกเวอร์ชันที่จะเก็บไว้"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "1 toDō ایک سے زیادہ ڈیوائسز پر بدلا ہے۔ رکھنے والا ورژن منتخب کریں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "1 个 toDō 在多台设备上发生变化。请选择要保留的版本。"
          }
        }
      }
    },
    "A focused task system designed for clarity, urgency, and momentum. Create what matters. Complete it intentionally. Keep moving.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "نظام مهام مركز مصمم لتحقيق الوضوح والإلحاح والزخم. اصنع ما يهم. أكملها عمدا. استمر في التحرك."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un sistema de tareas enfocado diseñado para brindar claridad, urgencia e impulso. Crea lo que importa. Complétalo intencionalmente. Sigue moviéndote."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्पष्टता, तात्कालिकता और गति के लिए डिज़ाइन की गई एक केंद्रित कार्य प्रणाली। जो मायने रखता है उसे बनाएं. इसे जानबूझकर पूरा करें. चलते रहो."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Un sistema di attività mirato progettato per chiarezza, urgenza e slancio. Crea ciò che conta. Completalo intenzionalmente. Continua a muoverti."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "明確さ、緊急性、勢いを重視して設計された集中タスク システム。重要なものを作成します。意図的に完成させてください。動き続けてください。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistem tugas berfokus yang direka bentuk untuk kejelasan, segera dan momentum. Cipta apa yang penting. Selesaikan dengan sengaja. Teruskan bergerak."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ระบบงานที่มุ่งเน้นซึ่งออกแบบมาเพื่อความชัดเจน ความเร่งด่วน และโมเมนตัม สร้างสิ่งที่สำคัญ ทำมันให้เสร็จอย่างตั้งใจ เดินหน้าต่อไป"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ایک فوکسڈ ٹاسک سسٹم جو وضاحت، عجلت اور رفتار کے لیے ڈیزائن کیا گیا ہے۔ جو اہم ہے وہ بنائیں۔ جان بوجھ کر مکمل کریں۔ چلتے رہیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "专为清晰、紧迫和动力而设计的重点任务系统。创造重要的事情。有意识地完成它。继续前进。"
          }
        }
      }
    },
    "A quieter two-note sound.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "صوت هادئ من نغمتين."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un sonido suave de dos tonos."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "दो सुरों वाली शांत ध्वनि।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Un suono piu delicato a due note."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "控えめな2音のサウンド。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Bunyi dua nada yang lebih lembut."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เสียงสองโน้ตที่นุ่มกว่า"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "دو نوٹ کی نرم آواز۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "较柔和的双音提示。"
          }
        }
      }
    },
    "A sharper sound for clear reminders.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "صوت أوضح للتذكيرات المهمة."
          }

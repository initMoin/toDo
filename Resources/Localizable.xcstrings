        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Verificar las tareas pendientes locales antes de sincronizar."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सिंक करने से पहले स्थानीय toDōs की जाँच करना।"
          }
        },
        "it": {

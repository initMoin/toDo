        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Segna un toDō attivo come fatto."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクティブなtoDōを完了にします。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tandakan toDō aktif sebagai selesai."
          }
        },

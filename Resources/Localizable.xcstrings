    "Capture something important. A task, reminder, responsibility, or idea.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "التقاط شيء مهم. مهمة أو تذكير أو مسؤولية أو فكرة."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Captura algo importante. Una tarea, recordatorio, responsabilidad o idea."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कोई महत्वपूर्ण चीज़ कैप्चर करें. कोई कार्य, अनुस्मारक, जिम्मेदारी, या विचार।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",

          "stringUnit": {
            "state": "translated",
            "value": "%@ इस्तेमाल करने के लिए तैयार हों तो toDō बंद करके फिर खोलें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Chiudi e riapri toDō quando vuoi usare %@."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@を使う準備ができたらtoDōを閉じて開き直してください。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutup dan buka semula toDō apabila sedia menggunakan %@."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",

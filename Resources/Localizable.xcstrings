            "value": "Puedes quedarte en este dispositivo."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आप इसी डिवाइस पर रह सकते हैं।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Puoi restare su questo dispositivo."
          }
        },
        "ja": {
          "stringUnit": {

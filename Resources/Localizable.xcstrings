    "Use the device default.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدام الإعداد الافتراضي للجهاز."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usar el valor predeterminado del dispositivo."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "डिवाइस डिफ़ॉल्ट इस्तेमाल करें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa il valore predefinito del dispositivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デバイスのデフォルトを使用します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Guna lalai peranti."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ใช้ค่าเริ่มต้นของอุปกรณ์"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ڈیوائس کا ڈیفالٹ استعمال کریں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用设备默认值。"
          }
        }
      }
    },
    "Use the device setting, or keep toDō light or dark.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدم إعداد الجهاز أو اجعل تُدُ فاتحًا أو داكنًا."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa el ajuste del dispositivo, o mantén toDō claro u oscuro."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "डिवाइस सेटिंग इस्तेमाल करें, या toDō को लाइट/डार्क रखें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa l'impostazione del dispositivo, oppure mantieni toDō chiaro o scuro."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デバイス設定を使うか、toDōをライトまたはダークに固定します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Guna tetapan peranti, atau kekalkan toDō cerah atau gelap."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ใช้การตั้งค่าอุปกรณ์ หรือให้ toDō เป็นสว่าง/มืด"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ڈیوائس setting استعمال کریں، یا toDō کو light یا dark رکھیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用设备设置，或让 toDō 保持浅色或深色。"
          }
        }
      }
    },
    "Use the Digital Crown here. The main form stays easy to scroll.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدم Digital Crown هنا. يظل النموذج الرئيسي سهل التمرير."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa la Digital Crown aquí. El formulario principal sigue siendo fácil de desplazar."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यहाँ Digital Crown का उपयोग करें. मुख्य फ़ॉर्म स्क्रॉल करना आसान रहता है."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa la Digital Crown qui. Il modulo principale resta facile da scorrere."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ここではDigital Crownを使います。メインフォームはスクロールしやすいままです。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Guna Digital Crown di sini. Borang utama kekal mudah ditatal."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ใช้ Digital Crown ที่นี่ ฟอร์มหลักยังเลื่อนได้ง่าย"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "یہاں Digital Crown استعمال کریں۔ مرکزی فارم اسکرول کرنا آسان رہتا ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在这里使用 Digital Crown。主表单仍然易于滚动。"
          }
        }
      }
    },
    "Use What Is Already There": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدام الموجود بالفعل"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usar lo que ya esta ahi"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जो पहले से है उसे इस्तेमाल करें"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa cio che c'e gia"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "既存のものを使う"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Guna Yang Sudah Ada"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ใช้สิ่งที่มีอยู่แล้ว"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "جو پہلے سے موجود ہے استعمال کریں"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用已有内容"
          }
        }
      }
    },
    "Use what is already there first to avoid duplicates.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدم الموجود بالفعل أولًا لتجنب التكرارات."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa primero lo que ya esta ahi para evitar duplicados."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "डुप्लिकेट से बचने के लिए पहले मौजूदा चीजें इस्तेमाल करें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa prima cio che c'e gia per evitare duplicati."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "重複を避けるため、まず既存のものを使います。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Guna yang sudah ada dahulu untuk mengelakkan pendua."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ใช้สิ่งที่มีอยู่ก่อนเพื่อเลี่ยงรายการซ้ำ"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "نقل سے بچنے کے لیے پہلے جو موجود ہے اسے استعمال کریں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "先使用已有内容以避免重复。"
          }
        }
      }
    },
    "Use your own words. Submit project proposal, pick up groceries, or call Sarah at 4 PM all work.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدم كلماتك الخاصة. أرسل مقترح المشروع، أو احصل على البقالة، أو اتصل بسارة في الساعة 4 مساءً."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa tus propias palabras. Envíe una propuesta de proyecto, recoja alimentos o llame a Sarah a las 4 p. m., todo funciona."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपने स्वंय के शब्द प्रयोग करो। प्रोजेक्ट प्रस्ताव सबमिट करें, किराने का सामान लें, या सभी काम के लिए शाम 4 बजे सारा को कॉल करें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa le tue parole. Invia una proposta di progetto, ritira la spesa o chiama Sarah alle 16:00, tutto funziona."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自分の言葉を使ってください。プロジェクトの提案書を提出したり、食料品を買ったり、午後 4 時にサラに電話したりするのはすべて仕事です。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Gunakan perkataan anda sendiri. Serahkan cadangan projek, ambil barang runcit atau hubungi Sarah pada pukul 4 petang semua kerja."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ใช้คำพูดของคุณเอง ส่งข้อเสนอโครงการ รับของชำ หรือโทรหา Sarah เวลา 16.00 น. ทุกงาน"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اپنے الفاظ استعمال کریں۔ پروجیکٹ پروپوزل جمع کروائیں، گروسری اٹھائیں، یا سارا کام شام 4 بجے سارہ کو کال کریں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用你自己的话。提交项目提案、取杂货或在下午 4 点给莎拉打电话，这些都是工作。"
          }
        }
      }
    },
    "Use your toDō account for iPhone, Android, and web.": {
      "localizations": {

    "Use a stronger double alert for due ToDos.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدم تنبيهًا مزدوجًا أقوى لـ تُدُس المستحقة."
          }
        },
        "es": {
          "stringUnit": {

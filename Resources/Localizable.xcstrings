    "Delete this toDō?": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هل تريد حذف هذا تُدُ؟"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Eliminar esta tarea pendiente?"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह कार्य हटाएं?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Eliminare questo toDō?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このtoDōを削除しますか？"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Padam toDō ini?"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ลบ toDō นี้?"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "یہ ٹُڈُو حذف کریں؟"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "删除此待办事项吗？"
          }
        }
      }
    },
    "Delete unused tags?": {
      "localizations": {

    "Notification access is disabled, so due reminders and push registration are unavailable.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم تعطيل الوصول إلى الإشعارات، لذا لا تتوفر التذكيرات المستحقة والتسجيل الفوري."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El acceso a las notificaciones está deshabilitado, por lo que los recordatorios de vencimiento y el registro automático no están disponibles."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अधिसूचना पहुंच अक्षम है, इसलिए उचित अनुस्मारक और पुश पंजीकरण अनुपलब्ध हैं।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'accesso alle notifiche è disabilitato, quindi i promemoria dovuti e la registrazione push non sono disponibili."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "通知へのアクセスが無効になっているため、期日のリマインダーやプッシュ登録は利用できません。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Akses pemberitahuan dilumpuhkan, jadi peringatan yang sewajarnya dan pendaftaran tolak tidak tersedia."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การเข้าถึงการแจ้งเตือนถูกปิดใช้งาน ดังนั้นการแจ้งเตือนที่ครบกำหนดและการลงทะเบียนแบบพุชจึงไม่สามารถใช้งานได้"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اطلاع تک رسائی غیر فعال ہے، اس لیے واجبی یاد دہانی اور پش رجسٹریشن دستیاب نہیں ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通知访问被禁用，因此到期提醒和推送注册不可用。"
          }
        }
      }
    },

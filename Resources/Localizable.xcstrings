          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การเข้าถึงตำแหน่งไม่พร้อมใช้งาน"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "مقام تک رسائی دستیاب نہیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "位置访问不可用。"
          }
        }
      }
    },
    "Location is off, so toDō stays on Apple Park time.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الموقع متوقف، لذلك يبقى تُدُ على وقت Apple Park."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La ubicacion esta desactivada, asi que toDō usa la hora de Apple Park."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्थान बंद है, इसलिए toDō Apple Park समय पर रहता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La posizione e disattivata, quindi toDō resta sull'ora di Apple Park."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "位置情報がオフのため、toDōはApple Parkの時間を使います。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Lokasi dimatikan, jadi toDō kekal pada masa Apple Park."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ปิดตำแหน่งอยู่ ดังนั้น toDō จะใช้เวลา Apple Park"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "Location بند ہے، اس لیے toDō Apple Park وقت پر رہے گا۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "位置已关闭，因此 toDō 使用 Apple Park 时间。"
          }
        }
      }
    },

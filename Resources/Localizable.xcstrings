    "Checking local ToDos before syncing.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "التحقق من المهام المحلية قبل المزامنة."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Verificar las tareas pendientes locales antes de sincronizar."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सिंक करने से पहले स्थानीय ToDos की जाँच करना।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Controllo delle cose da fare locali prima della sincronizzazione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "同期する前にローカル ToDo を確認します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Menyemak ToDos setempat sebelum menyegerak."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ตรวจสอบสิ่งที่ต้องทำในเครื่องก่อนทำการซิงค์"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "مطابقت پذیری سے پہلے مقامی ٹُڈُوز کی جانچ کر رہا ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "同步前检查本地待办事项。"
          }
        }
      }
    },
    "Checking your account for newer ToDos.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "التحقق من حسابك بحثًا عن تُدُس الأحدث."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Revisando su cuenta para ver si hay tareas pendientes más recientes."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "नए ToDos के लिए आपके खाते की जाँच की जा रही है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Controllo del tuo account per le attività da fare più recenti."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",

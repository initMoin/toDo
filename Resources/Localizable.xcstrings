    "Highest privacy. Your data stays on this device.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أعلى الخصوصية. تبقى بياناتك على هذا الجهاز."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Máxima privacidad. Tus datos permanecen en este dispositivo."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "उच्चतम गोपनीयता. आपका डेटा इस डिवाइस पर रहता है."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Massima privacy. I tuoi dati rimangono su questo dispositivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最高のプライバシー。データはこのデバイスに残ります。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Privasi tertinggi. Data anda kekal pada peranti ini."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "มีความเป็นส่วนตัวสูงสุด ข้อมูลของคุณยังคงอยู่ในอุปกรณ์นี้"

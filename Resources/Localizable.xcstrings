    "Signed out. toDōs stay on this device until you sign in to %@.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم تسجيل الخروج. تبقى المهام على هذا الجهاز حتى تقوم بتسجيل الدخول إلى%@."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cerrado sesión. Las tareas pendientes permanecen en este dispositivo hasta que inicie sesión en%@."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "साइन आउट कर दिया गया. जब तक आप%@में साइन इन नहीं कर लेते, तब तक toDōs इस डिवाइस पर बने रहेंगे।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Disconnesso. Le cose da fare rimangono su questo dispositivo finché non accedi a%@."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サインアウトしました。 toDō は、%@にサインインするまでこのデバイスに残ります。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Log keluar. toDōs kekal pada peranti ini sehingga anda log masuk ke%@."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ออกจากระบบแล้ว สิ่งที่ต้องทำจะยังคงอยู่ในอุปกรณ์นี้จนกว่าคุณจะลงชื่อเข้าใช้%@"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "سائن آؤٹ ہو گیا۔ جب تک آپ%@میں سائن ان نہیں کرتے ٹُڈُوز اس ڈیوائس پر رہتے ہیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已退出。在您登录%@之前，待办事项将保留在此设备上。"
          }
        }
      }
    },

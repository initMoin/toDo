    "Alerts that the toDō has reached its due moment.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تنبيهات بأن المهام قد وصلت إلى وقتها المحدد."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Alerta que el toDō ha llegado a su debido momento."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सचेत करता है कि टूडू अपने नियत समय पर पहुंच गया है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",

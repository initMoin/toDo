    },
    "ToDo is configured to sync through iCloud for Apple devices. This mode stays inside your private iCloud storage.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم تكوين تُدُ للمزامنة من خلالiCloudلأجهزةApple. يبقى هذا الوضع داخل وحدة تخزينiCloudالخاصة بك."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo está configurado para sincronizarse a través deiCloudpara dispositivosApple. Este modo permanece dentro de su almacenamiento privadoiCloud."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo कोAppleउपकरणों के लिएiCloudके माध्यम से सिंक करने के लिए कॉन्फ़िगर किया गया है। यह मोड आपके निजीiCloudस्टोरेज के अंदर रहता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo è configurato per la sincronizzazione tramiteiCloudper i dispositiviApple. Questa modalità rimane all'interno del tuo spazio di archiviazione privato ZXPLACEholder2ZX."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo は、AppleデバイスのiCloudを介して同期するように構成されています。このモードは、プライベートiCloudストレージ内に留まります。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tugasan dikonfigurasikan untuk menyegerak melaluiiClouduntuk perantiApple. Mod ini kekal dalam storaniCloudperibadi anda."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo ได้รับการกำหนดค่าให้ซิงค์ผ่านiCloudสำหรับอุปกรณ์Appleโหมดนี้จะยังคงอยู่ในที่เก็บข้อมูลiCloudส่วนตัวของคุณ"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ٹُڈُوAppleآلات کے لیےiCloudکے ذریعے مطابقت پذیر ہونے کے لیے ترتیب دیا گیا ہے۔ یہ موڈ آپ کے نجیiCloudاسٹوریج کے اندر رہتا ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo 配置为通过Apple设备的iCloud同步。此模式保留在您的私人iCloud存储中。"
          }
        }
      }
    },
    "ToDo is currently using %@.": {
      "localizations": {
        "ar": {
          "stringUnit": {

          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo हाल के परिवर्तनों को भेजने से पहले उन्हें बैच रहा है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo raggruppa le modifiche recenti prima di inviarle."
          }
        },
        "ja": {

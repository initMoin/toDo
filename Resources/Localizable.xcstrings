    "End the current Supabase session and return this device to local mode.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إنهاء جلسة Supabase الحالية وإرجاع هذا الجهاز إلى الوضع المحلي."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Finalice la sesión actual deSupabasey devuelva este dispositivo al modo local."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "वर्तमानSupabaseसत्र समाप्त करें और इस डिवाइस को स्थानीय मोड पर लौटाएँ।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Termina la sessione Supabase attuale e riporta questo dispositivo in modalità locale."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在のSupabaseセッションを終了し、このデバイスをローカルモードに戻します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tamatkan sesi Supabase semasa dan kembalikan peranti ini ke mod tempatan."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "สิ้นสุดเซสชัน Supabase ปัจจุบันและนำอุปกรณ์นี้กลับสู่โหมดในเครื่อง"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "موجودہ Supabase سیشن ختم کریں اور اس ڈیوائس کو مقامی موڈ پر واپس لائیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "结束当前的Supabase会话并将该设备返回到本地模式。"
          }
        }
      }
    },

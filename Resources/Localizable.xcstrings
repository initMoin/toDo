        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ٹُڈُو کھولیں اور فعال overdue ٹُڈُوز دکھائیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打开待办事项并显示活动的逾期待办事项。"
          }
        }
      }
    },

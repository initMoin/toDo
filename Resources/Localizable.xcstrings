    "Allow Always Location access so arrival and leaving reminders can work after toDō is closed.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اسمح بالوصول الدائم للموقع كي تعمل تذكيرات الوصول والمغادرة بعد إغلاق تُدُ."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Permita el acceso a Siempre ubicación para que los recordatorios de llegada y salida puedan funcionar después de que se cierre toDō."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हमेशा स्थान पहुंच की अनुमति दें ताकि आगमन और प्रस्थान अनुस्मारक toDō बंद होने के बाद काम कर सकें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Consenti sempre l'accesso alla posizione in modo che i promemoria di arrivo e partenza possano funzionare dopo la chiusura di toDō."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō が閉じられた後でも到着と出発のリマインダーが機能できるように、常に位置情報へのアクセスを許可します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Benarkan akses Lokasi Sentiasa supaya peringatan ketibaan dan keluar boleh berfungsi selepas Tugasan ditutup."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "อนุญาตการเข้าถึงตำแหน่งเสมอ เพื่อให้การเตือนเมื่อมาถึงและออกจากสามารถทำงานได้หลังจากปิด toDō"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ہمیشہ مقام تک رسائی دیں تاکہ ٹُڈُو بند ہونے کے بعد آمد اور روانگی کی یاد دہانیاں کام کریں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "允许“始终位置”访问，以便在待办事项关闭后可以使用到达和离开提醒。"
          }
        }
      }
    },
    "Allow notifications before testing a sound.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اسمح بالإشعارات قبل اختبار الصوت."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Permite las notificaciones antes de probar un sonido."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ध्वनि जांचने से पहले सूचनाएं अनुमति दें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Consenti le notifiche prima di provare un suono."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サウンドをテストする前に通知を許可してください。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Benarkan pemberitahuan sebelum menguji bunyi."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "อนุญาตการแจ้งเตือนก่อนทดสอบเสียง"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "آواز ٹیسٹ کرنے سے پہلے notifications کی اجازت دیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "测试声音前请先允许通知。"
          }
        }
      }
    },
    "Allow reminder alerts, sounds, and Time-Sensitive delivery.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اسمح بتنبيهات التذكير والأصوات والتسليم الحساس للوقت."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Permite alertas, sonidos y entrega urgente."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रिमाइंडर अलर्ट, ध्वनियां और Time-Sensitive डिलीवरी अनुमति दें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Consenti avvisi, suoni e consegna urgente."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リマインダー通知、サウンド、Time-Sensitive通知を許可します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Benarkan amaran peringatan, bunyi dan penghantaran Time-Sensitive."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "อนุญาตการเตือน เสียง และการส่งแบบ Time-Sensitive"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "یاد دہانی الرٹس، آوازوں اور Time-Sensitive ڈیلیوری کی اجازت دیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "允许提醒通知、声音和 Time-Sensitive 递送。"
          }
        }
      }
    },

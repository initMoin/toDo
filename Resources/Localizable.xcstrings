    "Move local toDōs into iCloud sync for Apple devices.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "انقل المهام المحلية إلى مزامنةiCloudلأجهزةApple."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mueva las tareas pendientes locales a la sincronizacióniCloudpara dispositivosApple."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Appleउपकरणों के लिए स्थानीय toDōs कोiCloudसिंक में ले जाएं।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sposta le attività locali nella sincronizzazioneiCloudper i dispositivi ZXPLACEholder1ZX."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ローカル toDō をAppleデバイスのiCloud同期に移動します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Alihkan toDōs setempat ke dalam penyegerakaniClouduntuk perantiApple."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ย้ายสิ่งที่ต้องทำในเครื่องไปยังการซิงค์iCloudสำหรับอุปกรณ์Apple"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "Appleآلات کے لیے مقامی ٹُڈُوز کوiCloudمطابقت پذیری میں منتقل کریں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将本地待办事项移至Apple设备的iCloud同步中。"
          }
        }
      }
    },

    "Quick picks set default times: Today %@, Tomorrow %@. Adjust time below.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تضبط الاختيارات السريعة أوقاتًا افتراضية: اليوم %@، غدًا %@. عدّل الوقت أدناه."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Quick picks set default times: Today %1$@, Tomorrow %2$@. Adjust time below."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las selecciones rápidas establecen tiempos predeterminados: hoy%@, mañana%@. Ajuste el tiempo a continuación."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "त्वरित चयन डिफ़ॉल्ट समय निर्धारित करते हैं: आज%@, कल%@। नीचे समय समायोजित करें."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le scelte rapide impostano orari predefiniti: oggi %@, domani %@. Regola l’orario qui sotto."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クイック選択では既定の時刻を設定します: 今日 %@、明日 %@。下で時刻を調整できます。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pilihan pantas menetapkan masa lalai: Hari ini %@, Esok %@. Laraskan masa di bawah."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ตัวเลือกด่วนจะตั้งเวลาเริ่มต้น: วันนี้ %@, พรุ่งนี้ %@ ปรับเวลาด้านล่าง"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "فوری انتخاب ڈیفالٹ اوقات سیٹ کرتے ہیں: آج %@، کل %@۔ نیچے وقت ایڈجسٹ کریں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "快速选择设置默认时间：今天%@，明天%@。下面调整时间。"
          }
        }
      }
    },

    "Mark an active toDō as done.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "وضع علامة على تُدُ نشط كمكتمل."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Marcar una tarea pendiente activa como terminada."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "किसी सक्रिय toDō को हो गया के रूप में चिह्नित करें."

    "Choose iCloud for Apple-only syncing. Choose toDō Sync for Android or web access too.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر iCloud للمزامنة بين أجهزة Apple فقط. اختر مزامنة تُدُ لاستخدام Android أو الويب أيضًا."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige iCloud para sincronizar solo con Apple. Elige toDō Sync para Android o web tambien."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "केवल Apple सिंक के लिए iCloud चुनें। Android या वेब पहुंच के लिए toDō Sync चुनें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli iCloud per sincronizzare solo dispositivi Apple. Scegli toDō Sync anche per Android o web."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Appleだけで同期するならiCloudを選びます。AndroidやWebも使うならtoDō Syncを選びます。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pilih iCloud untuk sync Apple sahaja. Pilih toDō Sync untuk Android atau web juga."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เลือก iCloud สำหรับซิงก์เฉพาะ Apple เลือก toDō Sync หากต้องการ Android หรือเว็บด้วย"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "صرف Apple syncing کے لیے iCloud منتخب کریں۔ Android یا web کے لیے toDō Sync منتخب کریں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅在 Apple 设备间同步请选择 iCloud。还需要 Android 或网页访问请选择 toDō Sync。"
          }
        }
      }
    },
    "Choose the category this widget should show.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر الفئة التي يجب أن يعرضها هذا الويدجت."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",

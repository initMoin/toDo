    "Ready. Arrival and leaving reminders can work when toDō is not open.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "جاهز. يمكن لتذكيرات الوصول والمغادرة العمل عندما لا يكون تُدُ مفتوحًا."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Listo. Los recordatorios de llegada y salida pueden funcionar cuando toDō no está abierto."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "तैयार। टूडू खुला न होने पर आगमन और प्रस्थान अनुस्मारक काम कर सकते हैं।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Pronto. I promemoria di arrivo e partenza possono funzionare quando toDō non è aperto."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "準備ができて。 toDō が開いていない場合でも、到着と出発のリマインダーは機能します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "sedia. Peringatan ketibaan dan keluar boleh berfungsi apabila Tugasan tidak dibuka."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "พร้อม. การเตือนการมาถึงและการออกจากสามารถทำงานได้เมื่อ toDō ไม่ได้เปิดอยู่"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "تیار۔ آمد اور روانگی کی یاد دہانیاں ٹُڈُو بند ہونے پر بھی کام کر سکتی ہیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "准备好。当待办事项未打开时，到达和离开提醒可以发挥作用。"
          }
        }
      }
    },

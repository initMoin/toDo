    "Close and reopen toDō to use this choice.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أغلق تُدُ وأعد فتحه لاستخدام هذا الخيار."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cierra y vuelve a abrir toDō para usar esta opcion."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस विकल्प को इस्तेमाल करने के लिए toDō बंद करके फिर खोलें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Chiudi e riapri toDō per usare questa scelta."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この選択を使うにはtoDōを閉じて開き直してください。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutup dan buka semula toDō untuk menggunakan pilihan ini."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ปิดและเปิด toDō ใหม่เพื่อใช้ตัวเลือกนี้"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "یہ انتخاب استعمال کرنے کے لیے toDō بند کر کے دوبارہ کھولیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "关闭并重新打开 toDō 以使用此选择。"
          }
        }
      }
    },
    "Close and reopen toDō when you are ready to use %@.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أغلق تُدُ وأعد فتحه عندما تكون جاهزًا لاستخدام %@."
          }
        },
        "es": {
          "stringUnit": {

    "%@ active.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ نشط."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ activos."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ सक्रिय।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ attivi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 件がアクティブ。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ aktif."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",

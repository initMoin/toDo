    "Customize how toDō behaves, syncs, and notifies you.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قم بتخصيص كيفية تصرفتُدُومزامنته وإعلامك."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Personalice cómo se comporta, sincroniza y notificatoDō."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अनुकूलित करें किtoDōआपको कैसे व्यवहार करता है, समन्वयित करता है और आपको सूचित करता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Personalizza il comportamento, la sincronizzazione e le notifiche ditoDō."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "toDōの動作、同期、通知の方法をカスタマイズします。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Sesuaikan caratoDōberkelakuan, menyegerak dan memberitahu anda."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ปรับแต่งการทำงานของtoDōซิงค์ และแจ้งเตือนคุณ"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اپنی مرضی کے مطابق بنائیں کہٹُڈُوکس طرح برتاؤ کرتا ہے، مطابقت پذیر ہوتا ہے اور آپ کو مطلع کرتا ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "自定义toDō的行为、同步和通知方式。"
          }
        }
      }
    },

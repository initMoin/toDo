    "Blue-green focus with a sunlit accent.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تركيز أزرق مخضر مع لمسة مضيئة."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Enfoque azul verdoso con un acento soleado."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "धूप जैसे एक्सेंट के साथ नीला-हरा फोकस।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Focus blu-verde con un accento solare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "陽の差すアクセントを添えたブルーグリーン。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Fokus biru-hijau dengan aksen cerah."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "โทนฟ้าเขียวพร้อมสีเน้นเหมือนแสงแดด"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "دھوپ جیسے رنگ کے ساتھ نیلا سبز انداز۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "蓝绿色专注感，搭配阳光般的点缀。"
          }
        }
      }
    },
    "Bold red, dark ink, clean white, and electric lime.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أحمر جريء، حبر داكن، أبيض نقي، وأخضر ليموني كهربائي."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Rojo audaz, tinta oscura, blanco limpio y lima eléctrica."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "गहरा लाल, डार्क इंक, साफ़ सफ़ेद, और इलेक्ट्रिक लाइम।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rosso deciso, inchiostro scuro, bianco pulito e lime elettrico."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "大胆な赤、濃いインク、澄んだ白、エレクトリックライム。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Merah berani, dakwat gelap, putih bersih dan limau elektrik."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "แดงเด่น หมึกเข้ม ขาวสะอาด และเขียวไลม์ไฟฟ้า"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "شوخ سرخ، گہری سیاہی، صاف سفید، اور برقی لائم۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "大胆红色、深色墨感、干净白色与电光青柠。"
          }
        }
      }
    },
    "Breaks through Focus when the toDō needs immediate attention.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يخترقFocusعندما يحتاج تُدُ إلى اهتمام فوري."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "AtraviesaFocuscuando la tarea pendiente necesita atención inmediata."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जब toDō पर तत्काल ध्यान देने की आवश्यकता होती है तोFocusको तोड़ता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "AttraversaFocusquando l'attività da fare richiede attenzione immediata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō に直ちに対応する必要がある場合、Focusを突破します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "MenerobosFocusapabila Tugasan memerlukan perhatian segera."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "แยกFocusเมื่อ toDō ต้องการความสนใจทันที"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "Focusکے ذریعے ٹوٹ جاتا ہے جب ٹُڈُو کو فوری توجہ کی ضرورت ہوتی ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当 toDō 需要立即关注时突破Focus。"
          }
        }
      }
    },

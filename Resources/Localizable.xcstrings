    "Open toDō and show active overdue toDōs.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "افتح تُدُ واعرض تُدُس النشطة المتأخرة."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Abra Tareas pendientes y muestre las tareas pendientes vencidas activas."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "toDō खोलें और सक्रिय अतिदेय toDōs दिखाएं।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Apri toDō e mostra i toDō attivi scaduti."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "toDōを開いて期限切れのアクティブなtoDōを表示します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Buka toDō dan tunjuk toDō aktif yang tertunggak."
          }

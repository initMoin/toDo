    "NSCalendarsFullAccessUsageDescription": {
      "comment": "Calendar permission prompt copy.",
      "extractionState": "extracted_with_value",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يستخدم تُدُ الوصول إلى التقويم لإضافة تُدُس المجدولة ذات تواريخ الاستحقاق إلى تقويمك حتى تظهر مهامك بجانب أحداث يومك."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "ToDo uses Calendar access to add scheduled ToDos with due dates to your calendar so your tasks can appear alongside your day’s events."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ToDo usa el acceso al calendario para añadir ToDos programados con fechas límite a tu calendario, para que tus tareas aparezcan junto a los eventos del día."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ToDo कैलेंडर एक्सेस का उपयोग नियत तारीख वाले निर्धारित ToDos को आपके कैलेंडर में जोड़ने के लिए करता है, ताकि आपके कार्य दिन की घटनाओं के साथ दिखें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo usa l’accesso al calendario per aggiungere al tuo calendario i ToDo programmati con scadenze, così le attività compaiono insieme agli eventi della giornata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDoはカレンダーへのアクセスを使用して、期限のあるToDoをカレンダーに追加し、1日の予定と一緒に表示します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo menggunakan akses kalendar untuk menambah ToDo berjadual yang mempunyai tarikh akhir ke kalendar anda supaya tugasan muncul bersama acara harian anda."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo ใช้การเข้าถึงปฏิทินเพื่อเพิ่ม ToDo ที่มีกำหนดลงในปฏิทินของคุณ เพื่อให้งานแสดงร่วมกับกิจกรรมประจำวันของคุณ"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ٹُڈُو کیلنڈر رسائی استعمال کرتا ہے تاکہ مقررہ تاریخ والے scheduled ٹُڈُوز آپ کے کیلنڈر میں شامل کیے جا سکیں اور آپ کے کام دن کے events کے ساتھ نظر آئیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ToDo 使用日历访问权限，将带有截止日期的计划 ToDo 添加到你的日历中，让任务与当天事件一起显示。"
          }
        }
      }
    },
    "NSCalendarsWriteOnlyAccessUsageDescription": {
      "comment": "Calendar write-only permission prompt copy.",
      "extractionState": "extracted_with_value",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يضيف تُدُ تُدُس المستحقة إلى تقويمك عندما تختار عكسها هناك."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "ToDo adds due ToDos to your calendar when you choose to mirror them there."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ToDo añade los ToDos con fecha límite a tu calendario cuando eliges reflejarlos allí."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "जब आप चुनते हैं, ToDo नियत तारीख वाले ToDos को आपके कैलेंडर में जोड़ता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo aggiunge al tuo calendario i ToDo con scadenza quando scegli di rispecchiarli lì."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カレンダーに反映することを選ぶと、ToDoは期限のあるToDoをカレンダーに追加します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo menambah ToDo yang mempunyai tarikh akhir ke kalendar anda apabila anda memilih untuk mencerminkannya di sana."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo จะเพิ่ม ToDo ที่มีกำหนดลงในปฏิทินของคุณเมื่อคุณเลือกให้แสดงในปฏิทิน"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "جب آپ مقررہ ٹُڈُوز کو کیلنڈر میں دکھانے کا انتخاب کرتے ہیں تو ٹُڈُو انہیں آپ کے کیلنڈر میں شامل کرتا ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "当你选择同步到日历时，ToDo 会将有截止日期的 ToDo 添加到你的日历。"
          }
        }
      }
    },
    "NSLocationAlwaysAndWhenInUseUsageDescription": {
      "comment": "Always location permission prompt copy.",
      "extractionState": "extracted_with_value",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يستخدم تُدُ الموقع فقط عندما تختار تذكيرات الوصول أو المغادرة لـ تُدُس محددة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "ToDo uses location only when you choose arrival or leaving reminders for specific ToDos."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ToDo usa la ubicación solo cuando eliges recordatorios de llegada o salida para ToDos específicos."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ToDo स्थान का उपयोग केवल तब करता है जब आप किसी विशेष ToDo के लिए पहुँचने या निकलने के रिमाइंडर चुनते हैं।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo usa la posizione solo quando scegli promemoria di arrivo o partenza per ToDo specifici."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDoは、特定のToDoに到着または出発リマインダーを設定した場合にのみ位置情報を使用します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo menggunakan lokasi hanya apabila anda memilih peringatan tiba atau keluar untuk ToDo tertentu."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo ใช้ตำแหน่งเฉพาะเมื่อคุณเลือกการเตือนเมื่อมาถึงหรือออกจากสถานที่สำหรับ ToDo บางรายการเท่านั้น"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ٹُڈُو مقام صرف اس وقت استعمال کرتا ہے جب آپ مخصوص ٹُڈُوز کے لیے پہنچنے یا نکلنے کی یاد دہانیاں منتخب کرتے ہیں۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ToDo 只会在你为特定 ToDo 选择到达或离开提醒时使用位置。"
          }
        }
      }
    },
    "NSLocationWhenInUseUsageDescription": {
      "comment": "When-in-use location permission prompt copy.",
      "extractionState": "extracted_with_value",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يستخدم تُدُ موقعك لإعداد تذكيرات الوصول والمغادرة التي تختارها."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "ToDo uses your location to set up arrival and leaving reminders you choose."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ToDo usa tu ubicación para configurar los recordatorios de llegada y salida que elijas."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ToDo आपके चुने हुए पहुँचने और निकलने के रिमाइंडर सेट करने के लिए आपके स्थान का उपयोग करता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo usa la tua posizione per configurare i promemoria di arrivo e partenza che scegli."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDoは、選択した到着および出発リマインダーを設定するために位置情報を使用します。"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo menggunakan lokasi anda untuk menyediakan peringatan tiba dan keluar yang anda pilih."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ToDo ใช้ตำแหน่งของคุณเพื่อตั้งค่าการเตือนเมื่อมาถึงและออกจากสถานที่ตามที่คุณเลือก"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ٹُڈُو آپ کا مقام آپ کی منتخب کردہ پہنچنے اور نکلنے کی یاد دہانیاں سیٹ کرنے کے لیے استعمال کرتا ہے۔"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ToDo 使用你的位置来设置你选择的到达和离开提醒。"
          }
        }
      }
    }
  },
  "version": "1.0"
}
